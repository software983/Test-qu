[
    {
        "start": 0.0,
        "end": 12.58,
        "text": "بسم الله الرحمن الرحيم تبارك الذي بيده الملك وهو على كل شيء قدير"
    },
    {
        "start": 12.58,
        "end": 23.94,
        "text": "الذي خلق الموت والحياة ليبلوكم أيكم أحسن عملا ۚ وهو العزيز الغفور"
    },
    {
        "start": 23.94,
        "end": 42.12,
        "text": "الذي خلق سبع سماوات طباقا ۖ ما ترى في خلق الرحمن من تفاوت ۖ فارجع البصر هل ترى من فطور"
    },
    {
        "start": 42.12,
        "end": 52.92,
        "text": "ثم ارجع البصر كرتين ينقلب إليك البصر خاسئا وهو حسير"
    },
    {
        "start": 52.92,
        "end": 69.48,
        "text": "ولقد زينا السماء الدنيا بمصابيح وجعلناها رجوما للشياطين ۖ وأعتدنا لهم عذاب السعير"
    },
    {
        "start": 69.48,
        "end": 77.88,
        "text": "وللذين كفروا بربهم عذاب جهنم ۖ وبئس المصير"
    },
    {
        "start": 77.88,
        "end": 86.56,
        "text": "إذا ألقوا فيها سمعوا لها شهيقا وهي تفور"
    },
    {
        "start": 86.56,
        "end": 100.7,
        "text": "تكاد تميز من الغيظ ۖ كلما ألقي فيها فوج سألهم خزنتها ألم يأتكم نذير"
    },
    {
        "start": 100.7,
        "end": 119.64,
        "text": "قالوا بلى قد جاءنا نذير فكذبنا وقلنا ما نزل الله من شيء إن أنتم إلا في ضلال كبير"
    },
    {
        "start": 119.64,
        "end": 129.56,
        "text": "وقالوا لو كنا نسمع أو نعقل ما كنا في أصحاب السعير"
    },
    {
        "start": 129.56,
        "end": 137.14,
        "text": "فاعترفوا بذنبهم فسحقا لأصحاب السعير"
    },
    {
        "start": 137.14,
        "end": 150.14,
        "text": "إن الذين يخشون ربهم بالغيب لهم مغفرة وأجر كبير"
    },
    {
        "start": 150.14,
        "end": 160.9,
        "text": "وأسروا قولكم أو اجهروا به ۖ إنه عليم بذات الصدور"
    },
    {
        "start": 160.9,
        "end": 167.76,
        "text": "ألا يعلم من خلق وهو اللطيف الخبير"
    },
    {
        "start": 167.76,
        "end": 181.4,
        "text": "هو الذي جعل لكم الأرض ذلولا فامشوا في مناكبها وكلوا من رزقه ۖ وإليه النشور"
    },
    {
        "start": 181.4,
        "end": 192.94,
        "text": "أأمنتم من في السماء أن يخسف بكم الأرض فإذا هي تمور"
    },
    {
        "start": 192.94,
        "end": 208.1,
        "text": "أم أمنتم من في السماء أن يرسل عليكم حاصبا ۖ فستعلمون كيف نذير"
    },
    {
        "start": 208.1,
        "end": 218.5,
        "text": "ولقد كذب الذين من قبلهم فكيف كان نكير"
    },
    {
        "start": 218.5,
        "end": 240.76,
        "text": "أولم يروا إلى الطير فوقهم صافات ويقبضن ۚ ما يمسكهن إلا الرحمن ۚ إنه بكل شيء بصير"
    },
    {
        "start": 240.76,
        "end": 257.54,
        "text": "أمن هذا الذي هو جند لكم ينصركم من دون الرحمن ۚ إن الكافرون إلا في غرور"
    },
    {
        "start": 257.54,
        "end": 269.84,
        "text": "أمن هذا الذي يرزقكم إن أمسك رزقه ۚ بل لجوا في عتو ونفور"
    },
    {
        "start": 269.84,
        "end": 284.76,
        "text": "أفمن يمشي مكبا على وجهه أهدى أمن يمشي سويا على صراط مستقيم"
    },
    {
        "start": 284.76,
        "end": 297.8,
        "text": "قل هو الذي أنشأكم وجعل لكم السمع والأبصار والأفئدة ۖ قليلا ما تشكرون"
    },
    {
        "start": 297.8,
        "end": 304.98,
        "text": "قل هو الذي ذرأكم في الأرض وإليه تحشرون"
    },
    {
        "start": 304.98,
        "end": 313.24,
        "text": "ويقولون متى هذا الوعد إن كنتم صادقين"
    },
    {
        "start": 313.24,
        "end": 324.44,
        "text": "قل إنما العلم عند الله وإنما أنا نذير مبين"
    },
    {
        "start": 324.44,
        "end": 340.68,
        "text": "فلما رأوه زلفة سيئت وجوه الذين كفروا وقيل هذا الذي كنتم به تدعون"
    },
    {
        "start": 340.68,
        "end": 355.32,
        "text": "قل أرأيتم إن أهلكني الله ومن معي أو رحمنا فمن يجير الكافرين من عذاب أليم"
    },
    {
        "start": 355.32,
        "end": 368.74,
        "text": "قل هو الرحمن آمنا به وعليه توكلنا ۖ فستعلمون من هو في ضلال مبين"
    },
    {
        "start": 368.74,
        "end": 390.68,
        "text": "قل أرأيتم إن أصبح ماؤكم غورا فمن يأتيكم بماء معين"
    },
    {
        "start": 368.74,
        "end": 390.68,
        "text": "بسم الله الرحمن الرحيم ن ۚ والقلم وما يسطرون"
    },
    {
        "start": 390.68,
        "end": 396.38,
        "text": "ما أنت بنعمة ربك بمجنون"
    },
    {
        "start": 396.38,
        "end": 402.12,
        "text": "وإن لك لأجرا غير ممنون"
    },
    {
        "start": 402.12,
        "end": 406.88,
        "text": "وإنك لعلى خلق عظيم"
    },
    {
        "start": 406.88,
        "end": 410.6,
        "text": "فستبصر ويبصرون"
    },
    {
        "start": 410.6,
        "end": 413.96,
        "text": "بأييكم المفتون"
    },
    {
        "start": 413.96,
        "end": 425.9,
        "text": "إن ربك هو أعلم بمن ضل عن سبيله وهو أعلم بالمهتدين"
    },
    {
        "start": 425.9,
        "end": 430.12,
        "text": "فلا تطع المكذبين"
    },
    {
        "start": 430.12,
        "end": 434.08,
        "text": "ودوا لو تدهن فيدهنون"
    },
    {
        "start": 434.08,
        "end": 439.52,
        "text": "ولا تطع كل حلاف مهين"
    },
    {
        "start": 439.52,
        "end": 446.92,
        "text": "هماز مشاء بنميم"
    },
    {
        "start": 446.92,
        "end": 452.96,
        "text": "مناع للخير معتد أثيم"
    },
    {
        "start": 452.96,
        "end": 458.16,
        "text": "عتل بعد ذلك زنيم"
    },
    {
        "start": 458.8,
        "end": 464.16,
        "text": "أن كان ذا مال وبنين"
    },
    {
        "start": 464.16,
        "end": 471.82,
        "text": "إذا تتلى عليه آياتنا قال أساطير الأولين"
    },
    {
        "start": 471.82,
        "end": 476.28,
        "text": "سنسمه على الخرطوم"
    },
    {
        "start": 476.28,
        "end": 489.72,
        "text": "إنا بلوناهم كما بلونا أصحاب الجنة إذ أقسموا ليصرمنها مصبحين"
    },
    {
        "start": 489.72,
        "end": 492.9,
        "text": "ولا يستثنون"
    },
    {
        "start": 492.9,
        "end": 502.26,
        "text": "فطاف عليها طائف من ربك وهم نائمون"
    },
    {
        "start": 502.26,
        "end": 505.06,
        "text": "فأصبحت كالصريم"
    },
    {
        "start": 505.06,
        "end": 508.62,
        "text": "فتنادوا مصبحين"
    },
    {
        "start": 508.62,
        "end": 516.14,
        "text": "أن اغدوا على حرثكم إن كنتم صارمين"
    },
    {
        "start": 516.14,
        "end": 520.96,
        "text": "فانطلقوا وهم يتخافتون"
    },
    {
        "start": 520.96,
        "end": 528.06,
        "text": "أن لا يدخلنها اليوم عليكم مسكين"
    },
    {
        "start": 528.06,
        "end": 532.84,
        "text": "وغدوا على حرد قادرين"
    },
    {
        "start": 532.84,
        "end": 542.24,
        "text": "فلما رأوها قالوا إنا لضالون"
    },
    {
        "start": 542.88,
        "end": 545.72,
        "text": "بل نحن محرومون"
    },
    {
        "start": 546.38,
        "end": 552.48,
        "text": "قال أوسطهم ألم أقل لكم لولا تسبحون"
    },
    {
        "start": 553.04,
        "end": 560.44,
        "text": "قالوا سبحان ربنا إنا كنا ظالمين"
    },
    {
        "start": 560.44,
        "end": 567.44,
        "text": "فأقبل بعضهم على بعض يتلاومون"
    },
    {
        "start": 567.98,
        "end": 574.66,
        "text": "قالوا يا ويلنا إنا كنا طاغين"
    },
    {
        "start": 574.66,
        "end": 586.24,
        "text": "عسى ربنا أن يبدلنا خيرا منها إنا إلى ربنا راغبون"
    },
    {
        "start": 586.24,
        "end": 596.68,
        "text": "كذلك العذاب ۖ ولعذاب الآخرة أكبر ۚ لو كانوا يعلمون"
    },
    {
        "start": 596.68,
        "end": 605.62,
        "text": "إن للمتقين عند ربهم جنات النعيم"
    },
    {
        "start": 605.62,
        "end": 611.38,
        "text": "أفنجعل المسلمين كالمجرمين"
    },
    {
        "start": 611.38,
        "end": 615.54,
        "text": "ما لكم كيف تحكمون"
    },
    {
        "start": 615.54,
        "end": 621.28,
        "text": "أم لكم كتاب فيه تدرسون"
    },
    {
        "start": 621.28,
        "end": 627.2,
        "text": "إن لكم فيه لما تخيرون"
    },
    {
        "start": 627.2,
        "end": 638.54,
        "text": "أم لكم أيمان علينا بالغة إلى يوم القيامة ۙ إن لكم لما تحكمون"
    },
    {
        "start": 638.54,
        "end": 643.76,
        "text": "سلهم أيهم بذلك زعيم"
    },
    {
        "start": 643.76,
        "end": 654.9,
        "text": "أم لهم شركاء فليأتوا بشركائهم إن كانوا صادقين"
    },
    {
        "start": 654.9,
        "end": 664.66,
        "text": "يوم يكشف عن ساق ويدعون إلى السجود فلا يستطيعون"
    },
    {
        "start": 664.66,
        "end": 676.98,
        "text": "خاشعة أبصارهم ترهقهم ذلة ۖ وقد كانوا يدعون إلى السجود وهم سالمون"
    },
    {
        "start": 676.98,
        "end": 688.18,
        "text": "فذرني ومن يكذب بهذا الحديث ۖ سنستدرجهم من حيث لا يعلمون"
    },
    {
        "start": 688.18,
        "end": 694.76,
        "text": "وأملي لهم ۚ إن كيدي متين"
    },
    {
        "start": 694.76,
        "end": 703.7,
        "text": "أم تسألهم أجرا فهم من مغرم مثقلون"
    },
    {
        "start": 703.7,
        "end": 710.1,
        "text": "أم عندهم الغيب فهم يكتبون"
    },
    {
        "start": 710.1,
        "end": 719.54,
        "text": "فاصبر لحكم ربك ولا تكن كصاحب الحوت إذ نادى وهو مكظوم"
    },
    {
        "start": 720.16,
        "end": 731.78,
        "text": "لولا أن تداركه نعمة من ربه لنبذ بالعراء وهو مذموم"
    },
    {
        "start": 731.78,
        "end": 737.78,
        "text": "فاجتباه ربه فجعله من الصالحين"
    },
    {
        "start": 737.78,
        "end": 753.8,
        "text": "وإن يكاد الذين كفروا ليزلقونك بأبصارهم لما سمعوا الذكر ويقولون إنه لمجنون"
    },
    {
        "start": 753.8,
        "end": 765.5,
        "text": "وما هو إلا ذكر للعالمين"
    },
    {
        "start": 753.8,
        "end": 765.5,
        "text": "بسم الله الرحمن الرحيم الحاقة"
    },
    {
        "start": 753.8,
        "end": 765.5,
        "text": "ما الحاقة"
    },
    {
        "start": 765.5,
        "end": 771.7,
        "text": "وما أدراك ما الحاقة"
    },
    {
        "start": 771.7,
        "end": 777.1,
        "text": "كذبت ثمود وعاد بالقارعة"
    },
    {
        "start": 777.1,
        "end": 782.88,
        "text": "فأما ثمود فأهلكوا بالطاغية"
    },
    {
        "start": 782.88,
        "end": 791.84,
        "text": "وأما عاد فأهلكوا بريح صرصر عاتية"
    },
    {
        "start": 791.84,
        "end": 810.34,
        "text": "سخرها عليهم سبع ليال وثمانية أيام حسوما فترى القوم فيها صرعى كأنهم أعجاز نخل خاوية"
    },
    {
        "start": 810.34,
        "end": 816.4,
        "text": "فهل ترى لهم من باقية"
    },
    {
        "start": 816.4,
        "end": 825.26,
        "text": "وجاء فرعون ومن قبله والمؤتفكات بالخاطئة"
    },
    {
        "start": 825.84,
        "end": 831.98,
        "text": "فعصوا رسول ربهم فأخذهم أخذة رابية"
    },
    {
        "start": 831.98,
        "end": 849.66,
        "text": "إنا لما طغى الماء حملناكم في الجارية"
    },
    {
        "start": 831.98,
        "end": 849.66,
        "text": "لنجعلها لكم تذكرة وتعيها أذن واعية"
    },
    {
        "start": 849.66,
        "end": 856.1,
        "text": "فإذا نفخ في الصور نفخة واحدة"
    },
    {
        "start": 856.1,
        "end": 864.04,
        "text": "وحملت الأرض والجبال فدكتا دكة واحدة"
    },
    {
        "start": 864.04,
        "end": 869.12,
        "text": "فيومئذ وقعت الواقعة"
    },
    {
        "start": 869.12,
        "end": 876.86,
        "text": "وانشقت السماء فهي يومئذ واهية"
    },
    {
        "start": 876.86,
        "end": 889.8,
        "text": "والملك على أرجائها ۚ ويحمل عرش ربك فوقهم يومئذ ثمانية"
    },
    {
        "start": 889.8,
        "end": 897.48,
        "text": "يومئذ تعرضون لا تخفى منكم خافية"
    },
    {
        "start": 897.48,
        "end": 909.06,
        "text": "فأما من أوتي كتابه بيمينه فيقول هاؤم اقرءوا كتابيه"
    },
    {
        "start": 909.06,
        "end": 916.54,
        "text": "إني ظننت أني ملاق حسابيه"
    },
    {
        "start": 916.54,
        "end": 924.9,
        "text": "فهو في عيشة راضية"
    },
    {
        "start": 916.54,
        "end": 924.9,
        "text": "في جنة عالية"
    },
    {
        "start": 924.9,
        "end": 928.34,
        "text": "قطوفها دانية"
    },
    {
        "start": 928.34,
        "end": 938.38,
        "text": "كلوا واشربوا هنيئا بما أسلفتم في الأيام الخالية"
    },
    {
        "start": 938.38,
        "end": 949.86,
        "text": "وأما من أوتي كتابه بشماله فيقول يا ليتني لم أوت كتابيه"
    },
    {
        "start": 950.4,
        "end": 953.9,
        "text": "ولم أدر ما حسابيه"
    },
    {
        "start": 953.9,
        "end": 958.3,
        "text": "يا ليتها كانت القاضية"
    },
    {
        "start": 958.3,
        "end": 963.4,
        "text": "ما أغنى عني ماليه ۜ"
    },
    {
        "start": 963.4,
        "end": 967.2,
        "text": "هلك عني سلطانيه"
    },
    {
        "start": 967.2,
        "end": 970.66,
        "text": "خذوه فغلوه"
    },
    {
        "start": 971.24,
        "end": 975.96,
        "text": "ثم الجحيم صلوه"
    },
    {
        "start": 975.96,
        "end": 991.56,
        "text": "ثم في سلسلة ذرعها سبعون ذراعا فاسلكوه"
    },
    {
        "start": 975.96,
        "end": 991.56,
        "text": "إنه كان لا يؤمن بالله العظيم"
    },
    {
        "start": 992.2,
        "end": 997.0,
        "text": "ولا يحض على طعام المسكين"
    },
    {
        "start": 997.58,
        "end": 1002.22,
        "text": "فليس له اليوم هاهنا حميم"
    },
    {
        "start": 1002.22,
        "end": 1008.06,
        "text": "ولا طعام إلا من غسلين"
    },
    {
        "start": 1008.06,
        "end": 1013.12,
        "text": "لا يأكله إلا الخاطئون"
    },
    {
        "start": 1013.12,
        "end": 1018.52,
        "text": "فلا أقسم بما تبصرون"
    },
    {
        "start": 1018.52,
        "end": 1022.2,
        "text": "وما لا تبصرون"
    },
    {
        "start": 1022.2,
        "end": 1028.88,
        "text": "إنه لقول رسول كريم"
    },
    {
        "start": 1028.88,
        "end": 1037.52,
        "text": "وما هو بقول شاعر ۚ قليلا ما تؤمنون"
    },
    {
        "start": 1037.52,
        "end": 1045.9,
        "text": "ولا بقول كاهن ۚ قليلا ما تذكرون"
    },
    {
        "start": 1045.9,
        "end": 1051.66,
        "text": "تنزيل من رب العالمين"
    },
    {
        "start": 1051.66,
        "end": 1056.9,
        "text": "ولو تقول علينا بعض الأقاويل"
    },
    {
        "start": 1056.9,
        "end": 1061.58,
        "text": "لأخذنا منه باليمين"
    },
    {
        "start": 1061.58,
        "end": 1066.62,
        "text": "ثم لقطعنا منه الوتين"
    },
    {
        "start": 1066.62,
        "end": 1073.94,
        "text": "فما منكم من أحد عنه حاجزين"
    },
    {
        "start": 1073.94,
        "end": 1079.74,
        "text": "وإنه لتذكرة للمتقين"
    },
    {
        "start": 1079.74,
        "end": 1088.26,
        "text": "وإنا لنعلم أن منكم مكذبين"
    },
    {
        "start": 1088.26,
        "end": 1094.38,
        "text": "وإنه لحسرة على الكافرين"
    },
    {
        "start": 1094.38,
        "end": 1098.62,
        "text": "وإنه لحق اليقين"
    },
    {
        "start": 1098.62,
        "end": 1108.9,
        "text": "فسبح باسم ربك العظيم"
    },
    {
        "start": 1098.62,
        "end": 1108.9,
        "text": "بسم الله الرحمن الرحيم سأل سائل بعذاب واقع"
    },
    {
        "start": 1108.9,
        "end": 1114.24,
        "text": "للكافرين ليس له دافع"
    },
    {
        "start": 1114.24,
        "end": 1118.08,
        "text": "من الله ذي المعارج"
    },
    {
        "start": 1118.08,
        "end": 1130.62,
        "text": "تعرج الملائكة والروح إليه في يوم كان مقداره خمسين ألف سنة"
    },
    {
        "start": 1130.62,
        "end": 1134.08,
        "text": "فاصبر صبرا جميلا"
    },
    {
        "start": 1134.08,
        "end": 1139.32,
        "text": "إنهم يرونه بعيدا"
    },
    {
        "start": 1140.3,
        "end": 1142.52,
        "text": "ونراه قريبا"
    },
    {
        "start": 1143.56,
        "end": 1147.96,
        "text": "يوم تكون السماء كالمهل"
    },
    {
        "start": 1148.76,
        "end": 1152.12,
        "text": "وتكون الجبال كالعهن"
    },
    {
        "start": 1153.04,
        "end": 1157.1,
        "text": "ولا يسأل حميم حميما"
    },
    {
        "start": 1158.54,
        "end": 1185.42,
        "text": "يبصرونهم ۚ يود المجرم لو يفتدي من عذاب يومئذ ببنيه"
    },
    {
        "start": 1159.94,
        "end": 1185.42,
        "text": "وصاحبته وأخيه"
    },
    {
        "start": 1159.94,
        "end": 1185.42,
        "text": "وفصيلته التي تؤويه"
    },
    {
        "start": 1159.94,
        "end": 1185.42,
        "text": "ومن في الأرض جميعا ثم ينجيه"
    },
    {
        "start": 1185.42,
        "end": 1207.04,
        "text": "كلا ۖ إنها لظى"
    },
    {
        "start": 1185.42,
        "end": 1207.04,
        "text": "نزاعة للشوى"
    },
    {
        "start": 1185.42,
        "end": 1207.04,
        "text": "تدعو من أدبر وتولى"
    },
    {
        "start": 1185.42,
        "end": 1207.04,
        "text": "وجمع فأوعى"
    },
    {
        "start": 1185.42,
        "end": 1207.04,
        "text": "۞ إن الإنسان خلق هلوعا"
    },
    {
        "start": 1207.04,
        "end": 1211.32,
        "text": "إذا مسه الشر جزوعا"
    },
    {
        "start": 1211.94,
        "end": 1216.16,
        "text": "وإذا مسه الخير منوعا"
    },
    {
        "start": 1216.72,
        "end": 1219.4,
        "text": "إلا المصلين"
    },
    {
        "start": 1219.4,
        "end": 1226.56,
        "text": "الذين هم على صلاتهم دائمون"
    },
    {
        "start": 1226.56,
        "end": 1233.06,
        "text": "والذين في أموالهم حق معلوم"
    },
    {
        "start": 1233.06,
        "end": 1238.16,
        "text": "للسائل والمحروم"
    },
    {
        "start": 1238.16,
        "end": 1243.42,
        "text": "والذين يصدقون بيوم الدين"
    },
    {
        "start": 1243.42,
        "end": 1250.64,
        "text": "والذين هم من عذاب ربهم مشفقون"
    },
    {
        "start": 1250.64,
        "end": 1256.26,
        "text": "إن عذاب ربهم غير مأمون"
    },
    {
        "start": 1256.26,
        "end": 1261.16,
        "text": "والذين هم لفروجهم حافظون"
    },
    {
        "start": 1261.16,
        "end": 1272.9,
        "text": "إلا على أزواجهم أو ما ملكت أيمانهم فإنهم غير ملومين"
    },
    {
        "start": 1272.9,
        "end": 1281.74,
        "text": "فمن ابتغى وراء ذلك فأولئك هم العادون"
    },
    {
        "start": 1281.74,
        "end": 1288.72,
        "text": "والذين هم لأماناتهم وعهدهم راعون"
    },
    {
        "start": 1288.72,
        "end": 1296.08,
        "text": "والذين هم بشهاداتهم قائمون"
    },
    {
        "start": 1296.82,
        "end": 1302.24,
        "text": "والذين هم على صلاتهم يحافظون"
    },
    {
        "start": 1302.88,
        "end": 1308.72,
        "text": "أولئك في جنات مكرمون"
    },
    {
        "start": 1309.28,
        "end": 1314.72,
        "text": "فمال الذين كفروا قبلك مهطعين"
    },
    {
        "start": 1314.72,
        "end": 1320.68,
        "text": "عن اليمين وعن الشمال عزين"
    },
    {
        "start": 1320.68,
        "end": 1329.78,
        "text": "أيطمع كل امرئ منهم أن يدخل جنة نعيم"
    },
    {
        "start": 1329.78,
        "end": 1338.54,
        "text": "كلا ۖ إنا خلقناهم مما يعلمون"
    },
    {
        "start": 1338.54,
        "end": 1349.12,
        "text": "فلا أقسم برب المشارق والمغارب إنا لقادرون"
    },
    {
        "start": 1349.12,
        "end": 1357.74,
        "text": "على أن نبدل خيرا منهم وما نحن بمسبوقين"
    },
    {
        "start": 1357.74,
        "end": 1366.4,
        "text": "فذرهم يخوضوا ويلعبوا حتى يلاقوا يومهم الذي يوعدون"
    },
    {
        "start": 1366.4,
        "end": 1378.96,
        "text": "يوم يخرجون من الأجداث سراعا كأنهم إلى نصب يوفضون"
    },
    {
        "start": 1378.96,
        "end": 1405.78,
        "text": "خاشعة أبصارهم ترهقهم ذلة ۚ ذلك اليوم الذي كانوا يوعدون"
    },
    {
        "start": 1378.96,
        "end": 1405.78,
        "text": "بسم الله الرحمن الرحيم إنا أرسلنا نوحا إلى قومه أن أنذر قومك من قبل أن يأتيهم عذاب أليم"
    },
    {
        "start": 1405.78,
        "end": 1412.54,
        "text": "قال يا قوم إني لكم نذير مبين"
    },
    {
        "start": 1412.54,
        "end": 1418.54,
        "text": "أن اعبدوا الله واتقوه وأطيعون"
    },
    {
        "start": 1418.54,
        "end": 1441.0,
        "text": "يغفر لكم من ذنوبكم ويؤخركم إلى أجل مسمى ۚ إن أجل الله إذا جاء لا يؤخر ۖ لو كنتم تعلمون"
    },
    {
        "start": 1441.54,
        "end": 1449.72,
        "text": "قال رب إني دعوت قومي ليلا ونهارا"
    },
    {
        "start": 1450.46,
        "end": 1456.74,
        "text": "فلم يزدهم دعائي إلا فرارا"
    },
    {
        "start": 1456.74,
        "end": 1473.24,
        "text": "وإني كلما دعوتهم لتغفر لهم جعلوا أصابعهم في آذانهم واستغشوا ثيابهم وأصروا واستكبروا استكبارا"
    },
    {
        "start": 1474.1,
        "end": 1479.1,
        "text": "ثم إني دعوتهم جهارا"
    },
    {
        "start": 1479.1,
        "end": 1488.3,
        "text": "ثم إني أعلنت لهم وأسررت لهم إسرارا"
    },
    {
        "start": 1489.18,
        "end": 1496.7,
        "text": "فقلت استغفروا ربكم إنه كان غفارا"
    },
    {
        "start": 1496.7,
        "end": 1503.16,
        "text": "يرسل السماء عليكم مدرارا"
    },
    {
        "start": 1503.16,
        "end": 1517.04,
        "text": "ويمددكم بأموال وبنين ويجعل لكم جنات ويجعل لكم أنهارا"
    },
    {
        "start": 1517.9,
        "end": 1523.0,
        "text": "ما لكم لا ترجون لله وقارا"
    },
    {
        "start": 1523.68,
        "end": 1527.12,
        "text": "وقد خلقكم أطوارا"
    },
    {
        "start": 1527.12,
        "end": 1535.76,
        "text": "ألم تروا كيف خلق الله سبع سماوات طباقا"
    },
    {
        "start": 1535.76,
        "end": 1544.4,
        "text": "وجعل القمر فيهن نورا وجعل الشمس سراجا"
    },
    {
        "start": 1544.4,
        "end": 1551.38,
        "text": "والله أنبتكم من الأرض نباتا"
    },
    {
        "start": 1551.38,
        "end": 1558.5,
        "text": "ثم يعيدكم فيها ويخرجكم إخراجا"
    },
    {
        "start": 1558.5,
        "end": 1563.78,
        "text": "والله جعل لكم الأرض بساطا"
    },
    {
        "start": 1564.42,
        "end": 1569.64,
        "text": "لتسلكوا منها سبلا فجاجا"
    },
    {
        "start": 1569.64,
        "end": 1581.92,
        "text": "قال نوح رب إنهم عصوني واتبعوا من لم يزده ماله وولده إلا خسارا"
    },
    {
        "start": 1582.8,
        "end": 1586.84,
        "text": "ومكروا مكرا كبارا"
    },
    {
        "start": 1586.84,
        "end": 1607.08,
        "text": "وقالوا لا تذرن آلهتكم ولا تذرن ودا ولا سواعا ولا يغوث ويعوق ونسرا"
    },
    {
        "start": 1586.84,
        "end": 1613.24,
        "text": "وقد أضلوا كثيرا ۖ ولا تزد الظالمين إلا ضلالا"
    },
    {
        "start": 1613.24,
        "end": 1628.6,
        "text": "مما خطيئاتهم أغرقوا فأدخلوا نارا فلم يجدوا لهم من دون الله أنصارا"
    },
    {
        "start": 1629.12,
        "end": 1637.94,
        "text": "وقال نوح رب لا تذر على الأرض من الكافرين ديارا"
    },
    {
        "start": 1637.94,
        "end": 1649.86,
        "text": "إنك إن تذرهم يضلوا عبادك ولا يلدوا إلا فاجرا كفارا"
    },
    {
        "start": 1650.6,
        "end": 1667.82,
        "text": "رب اغفر لي ولوالدي ولمن دخل بيتي مؤمنا وللمؤمنين والمؤمنات ولا تزد الظالمين إلا تبارا"
    },
    {
        "start": 1667.82,
        "end": 1684.88,
        "text": "بسم الله الرحمن الرحيم قل أوحي إلي أنه استمع نفر من الجن فقالوا إنا سمعنا قرآنا عجبا"
    },
    {
        "start": 1684.88,
        "end": 1695.42,
        "text": "يهدي إلى الرشد فآمنا به ۖ ولن نشرك بربنا أحدا"
    },
    {
        "start": 1695.42,
        "end": 1705.32,
        "text": "وأنه تعالى جد ربنا ما اتخذ صاحبة ولا ولدا"
    },
    {
        "start": 1705.32,
        "end": 1713.0,
        "text": "وأنه كان يقول سفيهنا على الله شططا"
    },
    {
        "start": 1713.0,
        "end": 1725.72,
        "text": "وأنا ظننا أن لن تقول الإنس والجن على الله كذبا"
    },
    {
        "start": 1725.72,
        "end": 1740.06,
        "text": "وأنه كان رجال من الإنس يعوذون برجال من الجن فزادوهم رهقا"
    },
    {
        "start": 1740.06,
        "end": 1750.56,
        "text": "وأنهم ظنوا كما ظننتم أن لن يبعث الله أحدا"
    },
    {
        "start": 1750.56,
        "end": 1762.78,
        "text": "وأنا لمسنا السماء فوجدناها ملئت حرسا شديدا وشهبا"
    },
    {
        "start": 1762.78,
        "end": 1776.8,
        "text": "وأنا كنا نقعد منها مقاعد للسمع ۖ فمن يستمع الآن يجد له شهابا رصدا"
    },
    {
        "start": 1776.8,
        "end": 1788.42,
        "text": "وأنا لا ندري أشر أريد بمن في الأرض أم أراد بهم ربهم رشدا"
    },
    {
        "start": 1788.42,
        "end": 1801.44,
        "text": "وأنا منا الصالحون ومنا دون ذلك ۖ كنا طرائق قددا"
    },
    {
        "start": 1801.44,
        "end": 1813.74,
        "text": "وأنا ظننا أن لن نعجز الله في الأرض ولن نعجزه هربا"
    },
    {
        "start": 1813.74,
        "end": 1830.94,
        "text": "وأنا لما سمعنا الهدى آمنا به ۖ فمن يؤمن بربه فلا يخاف بخسا ولا رهقا"
    },
    {
        "start": 1831.52,
        "end": 1845.8,
        "text": "وأنا منا المسلمون ومنا القاسطون ۖ فمن أسلم فأولئك تحروا رشدا"
    },
    {
        "start": 1845.8,
        "end": 1853.84,
        "text": "وأما القاسطون فكانوا لجهنم حطبا"
    },
    {
        "start": 1853.84,
        "end": 1863.7,
        "text": "وأن لو استقاموا على الطريقة لأسقيناهم ماء غدقا"
    },
    {
        "start": 1863.7,
        "end": 1875.46,
        "text": "لنفتنهم فيه ۚ ومن يعرض عن ذكر ربه يسلكه عذابا صعدا"
    },
    {
        "start": 1876.08,
        "end": 1884.34,
        "text": "وأن المساجد لله فلا تدعوا مع الله أحدا"
    },
    {
        "start": 1884.34,
        "end": 1894.72,
        "text": "وأنه لما قام عبد الله يدعوه كادوا يكونون عليه لبدا"
    },
    {
        "start": 1894.72,
        "end": 1903.46,
        "text": "قل إنما أدعو ربي ولا أشرك به أحدا"
    },
    {
        "start": 1903.46,
        "end": 1910.22,
        "text": "قل إني لا أملك لكم ضرا ولا رشدا"
    },
    {
        "start": 1910.22,
        "end": 1922.22,
        "text": "قل إني لن يجيرني من الله أحد ولن أجد من دونه ملتحدا"
    },
    {
        "start": 1922.22,
        "end": 1941.02,
        "text": "إلا بلاغا من الله ورسالاته ۚ ومن يعص الله ورسوله فإن له نار جهنم خالدين فيها أبدا"
    },
    {
        "start": 1941.02,
        "end": 1952.66,
        "text": "حتى إذا رأوا ما يوعدون فسيعلمون من أضعف ناصرا وأقل عددا"
    },
    {
        "start": 1952.66,
        "end": 1962.42,
        "text": "قل إن أدري أقريب ما توعدون أم يجعل له ربي أمدا"
    },
    {
        "start": 1963.14,
        "end": 1969.38,
        "text": "عالم الغيب فلا يظهر على غيبه أحدا"
    },
    {
        "start": 1969.38,
        "end": 1982.22,
        "text": "إلا من ارتضى من رسول فإنه يسلك من بين يديه ومن خلفه رصدا"
    },
    {
        "start": 1982.22,
        "end": 2003.68,
        "text": "ليعلم أن قد أبلغوا رسالات ربهم وأحاط بما لديهم وأحصى كل شيء عددا"
    },
    {
        "start": 1982.22,
        "end": 2003.68,
        "text": "بسم الله الرحمن الرحيم يا أيها المزمل"
    },
    {
        "start": 1982.22,
        "end": 2003.68,
        "text": "قم الليل إلا قليلا"
    },
    {
        "start": 2003.68,
        "end": 2008.54,
        "text": "نصفه أو انقص منه قليلا"
    },
    {
        "start": 2008.54,
        "end": 2014.6,
        "text": "أو زد عليه ورتل القرآن ترتيلا"
    },
    {
        "start": 2014.6,
        "end": 2021.14,
        "text": "إنا سنلقي عليك قولا ثقيلا"
    },
    {
        "start": 2022.04,
        "end": 2031.38,
        "text": "إن ناشئة الليل هي أشد وطئا وأقوم قيلا"
    },
    {
        "start": 2031.38,
        "end": 2038.82,
        "text": "إن لك في النهار سبحا طويلا"
    },
    {
        "start": 2039.84,
        "end": 2045.42,
        "text": "واذكر اسم ربك وتبتل إليه تبتيلا"
    },
    {
        "start": 2045.42,
        "end": 2054.38,
        "text": "رب المشرق والمغرب لا إله إلا هو فاتخذه وكيلا"
    },
    {
        "start": 2054.38,
        "end": 2062.06,
        "text": "واصبر على ما يقولون واهجرهم هجرا جميلا"
    },
    {
        "start": 2062.72,
        "end": 2070.3,
        "text": "وذرني والمكذبين أولي النعمة ومهلهم قليلا"
    },
    {
        "start": 2070.92,
        "end": 2077.5,
        "text": "إن لدينا أنكالا وجحيما"
    },
    {
        "start": 2078.08,
        "end": 2084.28,
        "text": "وطعاما ذا غصة وعذابا أليما"
    },
    {
        "start": 2084.28,
        "end": 2093.48,
        "text": "يوم ترجف الأرض والجبال وكانت الجبال كثيبا مهيلا"
    },
    {
        "start": 2093.48,
        "end": 2106.64,
        "text": "إنا أرسلنا إليكم رسولا شاهدا عليكم كما أرسلنا إلى فرعون رسولا"
    },
    {
        "start": 2106.64,
        "end": 2114.62,
        "text": "فعصى فرعون الرسول فأخذناه أخذا وبيلا"
    },
    {
        "start": 2114.62,
        "end": 2124.58,
        "text": "فكيف تتقون إن كفرتم يوما يجعل الولدان شيبا"
    },
    {
        "start": 2124.58,
        "end": 2134.14,
        "text": "السماء منفطر به ۚ كان وعده مفعولا"
    },
    {
        "start": 2134.14,
        "end": 2145.24,
        "text": "إن هذه تذكرة ۖ فمن شاء اتخذ إلى ربه سبيلا"
    },
    {
        "start": 2145.24,
        "end": 2239.28,
        "text": "۞ إن ربك يعلم أنك تقوم أدنى من ثلثي الليل ونصفه وثلثه وطائفة من الذين معك ۚ والله يقدر الليل والنهار ۚ علم أن لن تحصوه فتاب عليكم ۖ فاقرءوا ما تيسر من القرآن ۚ علم أن سيكون منكم مرضى ۙ وآخرون يضربون في الأرض يبتغون من فضل الله ۙ وآخرون يقاتلون في سبيل الله ۖ فاقرءوا ما تيسر منه ۚ وأقيموا الصلاة وآتوا الزكاة وأقرضوا الله قرضا حسنا ۚ وما تقدموا لأنفسكم من خير تجدوه عند الله هو خيرا وأعظم أجرا ۚ واستغفروا الله ۖ إن الله غفور رحيم"
    },
    {
        "start": 2227.94,
        "end": 2239.28,
        "text": "بسم الله الرحمن الرحيم يا أيها المدثر"
    },
    {
        "start": 2239.28,
        "end": 2241.98,
        "text": "قم فأنذر"
    },
    {
        "start": 2241.98,
        "end": 2244.68,
        "text": "وربك فكبر"
    },
    {
        "start": 2244.68,
        "end": 2248.2,
        "text": "وثيابك فطهر"
    },
    {
        "start": 2248.2,
        "end": 2250.9,
        "text": "والرجز فاهجر"
    },
    {
        "start": 2250.9,
        "end": 2255.06,
        "text": "ولا تمنن تستكثر"
    },
    {
        "start": 2255.06,
        "end": 2258.4,
        "text": "ولربك فاصبر"
    },
    {
        "start": 2258.4,
        "end": 2262.64,
        "text": "فإذا نقر في الناقور"
    },
    {
        "start": 2262.64,
        "end": 2268.96,
        "text": "فذلك يومئذ يوم عسير"
    },
    {
        "start": 2268.96,
        "end": 2273.5,
        "text": "على الكافرين غير يسير"
    },
    {
        "start": 2273.5,
        "end": 2277.86,
        "text": "ذرني ومن خلقت وحيدا"
    },
    {
        "start": 2278.38,
        "end": 2283.36,
        "text": "وجعلت له مالا ممدودا"
    },
    {
        "start": 2283.36,
        "end": 2286.86,
        "text": "وبنين شهودا"
    },
    {
        "start": 2286.86,
        "end": 2290.94,
        "text": "ومهدت له تمهيدا"
    },
    {
        "start": 2290.94,
        "end": 2294.88,
        "text": "ثم يطمع أن أزيد"
    },
    {
        "start": 2294.88,
        "end": 2302.68,
        "text": "كلا ۖ إنه كان لآياتنا عنيدا"
    },
    {
        "start": 2302.68,
        "end": 2307.04,
        "text": "سأرهقه صعودا"
    },
    {
        "start": 2307.04,
        "end": 2311.2,
        "text": "إنه فكر وقدر"
    },
    {
        "start": 2311.2,
        "end": 2314.06,
        "text": "فقتل كيف قدر"
    },
    {
        "start": 2314.06,
        "end": 2318.36,
        "text": "ثم قتل كيف قدر"
    },
    {
        "start": 2318.36,
        "end": 2321.48,
        "text": "ثم نظر"
    },
    {
        "start": 2321.48,
        "end": 2325.22,
        "text": "ثم عبس وبسر"
    },
    {
        "start": 2325.22,
        "end": 2329.3,
        "text": "ثم أدبر واستكبر"
    },
    {
        "start": 2329.3,
        "end": 2335.66,
        "text": "فقال إن هذا إلا سحر يؤثر"
    },
    {
        "start": 2335.66,
        "end": 2340.14,
        "text": "إن هذا إلا قول البشر"
    },
    {
        "start": 2340.14,
        "end": 2343.34,
        "text": "سأصليه سقر"
    },
    {
        "start": 2343.34,
        "end": 2346.78,
        "text": "وما أدراك ما سقر"
    },
    {
        "start": 2346.78,
        "end": 2350.54,
        "text": "لا تبقي ولا تذر"
    },
    {
        "start": 2350.54,
        "end": 2354.1,
        "text": "لواحة للبشر"
    },
    {
        "start": 2354.1,
        "end": 2357.52,
        "text": "عليها تسعة عشر"
    },
    {
        "start": 2357.52,
        "end": 2433.08,
        "text": "وما جعلنا أصحاب النار إلا ملائكة ۙ وما جعلنا عدتهم إلا فتنة للذين كفروا ليستيقن الذين أوتوا الكتاب ويزداد الذين آمنوا إيمانا ۙ ولا يرتاب الذين أوتوا الكتاب والمؤمنون ۙ وليقول الذين في قلوبهم مرض والكافرون ماذا أراد الله بهذا مثلا ۚ كذلك يضل الله من يشاء ويهدي من يشاء ۚ وما يعلم جنود ربك إلا هو ۚ وما هي إلا ذكرى للبشر"
    },
    {
        "start": 2433.08,
        "end": 2436.38,
        "text": "كلا والقمر"
    },
    {
        "start": 2436.38,
        "end": 2439.3,
        "text": "والليل إذ أدبر"
    },
    {
        "start": 2439.3,
        "end": 2446.96,
        "text": "والصبح إذا أسفر"
    },
    {
        "start": 2439.3,
        "end": 2446.96,
        "text": "إنها لإحدى الكبر"
    },
    {
        "start": 2446.96,
        "end": 2468.32,
        "text": "نذيرا للبشر"
    },
    {
        "start": 2446.96,
        "end": 2468.32,
        "text": "لمن شاء منكم أن يتقدم أو يتأخر"
    },
    {
        "start": 2446.96,
        "end": 2468.32,
        "text": "كل نفس بما كسبت رهينة"
    },
    {
        "start": 2446.96,
        "end": 2468.32,
        "text": "إلا أصحاب اليمين"
    },
    {
        "start": 2468.32,
        "end": 2475.26,
        "text": "في جنات يتساءلون"
    },
    {
        "start": 2475.26,
        "end": 2478.34,
        "text": "عن المجرمين"
    },
    {
        "start": 2478.34,
        "end": 2482.28,
        "text": "ما سلككم في سقر"
    },
    {
        "start": 2482.28,
        "end": 2486.94,
        "text": "قالوا لم نك من المصلين"
    },
    {
        "start": 2486.94,
        "end": 2490.9,
        "text": "ولم نك نطعم المسكين"
    },
    {
        "start": 2490.9,
        "end": 2497.22,
        "text": "وكنا نخوض مع الخائضين"
    },
    {
        "start": 2497.22,
        "end": 2503.22,
        "text": "وكنا نكذب بيوم الدين"
    },
    {
        "start": 2503.22,
        "end": 2506.84,
        "text": "حتى أتانا اليقين"
    },
    {
        "start": 2506.84,
        "end": 2513.02,
        "text": "فما تنفعهم شفاعة الشافعين"
    },
    {
        "start": 2513.02,
        "end": 2518.34,
        "text": "فما لهم عن التذكرة معرضين"
    },
    {
        "start": 2518.34,
        "end": 2524.08,
        "text": "كأنهم حمر مستنفرة"
    },
    {
        "start": 2524.08,
        "end": 2527.82,
        "text": "فرت من قسورة"
    },
    {
        "start": 2527.82,
        "end": 2535.86,
        "text": "بل يريد كل امرئ منهم أن يؤتى صحفا منشرة"
    },
    {
        "start": 2536.44,
        "end": 2541.48,
        "text": "كلا ۖ بل لا يخافون الآخرة"
    },
    {
        "start": 2541.48,
        "end": 2545.56,
        "text": "كلا إنه تذكرة"
    },
    {
        "start": 2545.56,
        "end": 2550.28,
        "text": "فمن شاء ذكره"
    },
    {
        "start": 2550.28,
        "end": 2562.28,
        "text": "وما يذكرون إلا أن يشاء الله ۚ هو أهل التقوى وأهل المغفرة"
    },
    {
        "start": 2562.28,
        "end": 2566.66,
        "text": "بسم الله الرحمن الرحيم لا أقسم بيوم القيامة"
    },
    {
        "start": 2567.58,
        "end": 2572.72,
        "text": "ولا أقسم بالنفس اللوامة"
    },
    {
        "start": 2573.46,
        "end": 2579.66,
        "text": "أيحسب الإنسان ألن نجمع عظامه"
    },
    {
        "start": 2580.28,
        "end": 2587.02,
        "text": "بلى قادرين على أن نسوي بنانه"
    },
    {
        "start": 2587.02,
        "end": 2592.88,
        "text": "بل يريد الإنسان ليفجر أمامه"
    },
    {
        "start": 2592.88,
        "end": 2597.64,
        "text": "يسأل أيان يوم القيامة"
    },
    {
        "start": 2597.64,
        "end": 2600.82,
        "text": "فإذا برق البصر"
    },
    {
        "start": 2600.82,
        "end": 2603.08,
        "text": "وخسف القمر"
    },
    {
        "start": 2603.08,
        "end": 2606.48,
        "text": "وجمع الشمس والقمر"
    },
    {
        "start": 2606.48,
        "end": 2613.56,
        "text": "يقول الإنسان يومئذ أين المفر"
    },
    {
        "start": 2613.56,
        "end": 2616.44,
        "text": "كلا لا وزر"
    },
    {
        "start": 2616.44,
        "end": 2621.76,
        "text": "إلى ربك يومئذ المستقر"
    },
    {
        "start": 2621.76,
        "end": 2629.76,
        "text": "ينبأ الإنسان يومئذ بما قدم وأخر"
    },
    {
        "start": 2629.76,
        "end": 2635.68,
        "text": "بل الإنسان على نفسه بصيرة"
    },
    {
        "start": 2635.68,
        "end": 2639.88,
        "text": "ولو ألقى معاذيره"
    },
    {
        "start": 2640.46,
        "end": 2651.08,
        "text": "لا تحرك به لسانك لتعجل به"
    },
    {
        "start": 2640.46,
        "end": 2651.08,
        "text": "إن علينا جمعه وقرآنه"
    },
    {
        "start": 2651.6,
        "end": 2657.64,
        "text": "فإذا قرأناه فاتبع قرآنه"
    },
    {
        "start": 2657.64,
        "end": 2662.44,
        "text": "ثم إن علينا بيانه"
    },
    {
        "start": 2662.44,
        "end": 2670.6,
        "text": "كلا بل تحبون العاجلة"
    },
    {
        "start": 2662.44,
        "end": 2670.6,
        "text": "وتذرون الآخرة"
    },
    {
        "start": 2670.6,
        "end": 2675.7,
        "text": "وجوه يومئذ ناضرة"
    },
    {
        "start": 2675.7,
        "end": 2679.5,
        "text": "إلى ربها ناظرة"
    },
    {
        "start": 2679.5,
        "end": 2684.96,
        "text": "ووجوه يومئذ باسرة"
    },
    {
        "start": 2684.96,
        "end": 2690.26,
        "text": "تظن أن يفعل بها فاقرة"
    },
    {
        "start": 2690.26,
        "end": 2695.72,
        "text": "كلا إذا بلغت التراقي"
    },
    {
        "start": 2695.72,
        "end": 2698.9,
        "text": "وقيل من ۜ راق"
    },
    {
        "start": 2698.9,
        "end": 2704.02,
        "text": "وظن أنه الفراق"
    },
    {
        "start": 2704.02,
        "end": 2707.96,
        "text": "والتفت الساق بالساق"
    },
    {
        "start": 2707.96,
        "end": 2713.14,
        "text": "إلى ربك يومئذ المساق"
    },
    {
        "start": 2713.14,
        "end": 2716.62,
        "text": "فلا صدق ولا صلى"
    },
    {
        "start": 2716.62,
        "end": 2721.8,
        "text": "ولكن كذب وتولى"
    },
    {
        "start": 2721.8,
        "end": 2727.94,
        "text": "ثم ذهب إلى أهله يتمطى"
    },
    {
        "start": 2727.94,
        "end": 2731.16,
        "text": "أولى لك فأولى"
    },
    {
        "start": 2731.16,
        "end": 2735.66,
        "text": "ثم أولى لك فأولى"
    },
    {
        "start": 2735.66,
        "end": 2741.18,
        "text": "أيحسب الإنسان أن يترك سدى"
    },
    {
        "start": 2741.18,
        "end": 2749.18,
        "text": "ألم يك نطفة من مني يمنى"
    },
    {
        "start": 2750.0,
        "end": 2756.18,
        "text": "ثم كان علقة فخلق فسوى"
    },
    {
        "start": 2756.88,
        "end": 2762.18,
        "text": "فجعل منه الزوجين الذكر والأنثى"
    },
    {
        "start": 2762.18,
        "end": 2781.4,
        "text": "أليس ذلك بقادر على أن يحيي الموتى"
    },
    {
        "start": 2762.18,
        "end": 2781.4,
        "text": "بسم الله الرحمن الرحيم هل أتى على الإنسان حين من الدهر لم يكن شيئا مذكورا"
    },
    {
        "start": 2781.4,
        "end": 2795.74,
        "text": "إنا خلقنا الإنسان من نطفة أمشاج نبتليه فجعلناه سميعا بصيرا"
    },
    {
        "start": 2795.74,
        "end": 2805.8,
        "text": "إنا هديناه السبيل إما شاكرا وإما كفورا"
    },
    {
        "start": 2805.8,
        "end": 2816.2,
        "text": "إنا أعتدنا للكافرين سلاسل وأغلالا وسعيرا"
    },
    {
        "start": 2816.2,
        "end": 2826.32,
        "text": "إن الأبرار يشربون من كأس كان مزاجها كافورا"
    },
    {
        "start": 2826.32,
        "end": 2834.8,
        "text": "عينا يشرب بها عباد الله يفجرونها تفجيرا"
    },
    {
        "start": 2834.8,
        "end": 2844.72,
        "text": "يوفون بالنذر ويخافون يوما كان شره مستطيرا"
    },
    {
        "start": 2845.28,
        "end": 2855.46,
        "text": "ويطعمون الطعام على حبه مسكينا ويتيما وأسيرا"
    },
    {
        "start": 2855.46,
        "end": 2866.56,
        "text": "إنما نطعمكم لوجه الله لا نريد منكم جزاء ولا شكورا"
    },
    {
        "start": 2867.54,
        "end": 2875.06,
        "text": "إنا نخاف من ربنا يوما عبوسا قمطريرا"
    },
    {
        "start": 2876.06,
        "end": 2884.76,
        "text": "فوقاهم الله شر ذلك اليوم ولقاهم نضرة وسرورا"
    },
    {
        "start": 2885.46,
        "end": 2892.5,
        "text": "وجزاهم بما صبروا جنة وحريرا"
    },
    {
        "start": 2893.34,
        "end": 2903.86,
        "text": "متكئين فيها على الأرائك ۖ لا يرون فيها شمسا ولا زمهريرا"
    },
    {
        "start": 2904.62,
        "end": 2912.3,
        "text": "ودانية عليهم ظلالها وذللت قطوفها تذليلا"
    },
    {
        "start": 2912.3,
        "end": 2925.18,
        "text": "ويطاف عليهم بآنية من فضة وأكواب كانت قواريرا"
    },
    {
        "start": 2925.98,
        "end": 2933.1,
        "text": "قوارير من فضة قدروها تقديرا"
    },
    {
        "start": 2933.7,
        "end": 2941.4,
        "text": "ويسقون فيها كأسا كان مزاجها زنجبيلا"
    },
    {
        "start": 2941.4,
        "end": 2948.14,
        "text": "عينا فيها تسمى سلسبيلا"
    },
    {
        "start": 2948.14,
        "end": 2961.2,
        "text": "۞ ويطوف عليهم ولدان مخلدون إذا رأيتهم حسبتهم لؤلؤا منثورا"
    },
    {
        "start": 2962.06,
        "end": 2970.2,
        "text": "وإذا رأيت ثم رأيت نعيما وملكا كبيرا"
    },
    {
        "start": 2970.2,
        "end": 2989.0,
        "text": "عاليهم ثياب سندس خضر وإستبرق ۖ وحلوا أساور من فضة وسقاهم ربهم شرابا طهورا"
    },
    {
        "start": 2989.86,
        "end": 2999.78,
        "text": "إن هذا كان لكم جزاء وكان سعيكم مشكورا"
    },
    {
        "start": 2999.78,
        "end": 3008.66,
        "text": "إنا نحن نزلنا عليك القرآن تنزيلا"
    },
    {
        "start": 3008.66,
        "end": 3017.32,
        "text": "فاصبر لحكم ربك ولا تطع منهم آثما أو كفورا"
    },
    {
        "start": 3017.32,
        "end": 3022.5,
        "text": "واذكر اسم ربك بكرة وأصيلا"
    },
    {
        "start": 3022.5,
        "end": 3030.34,
        "text": "ومن الليل فاسجد له وسبحه ليلا طويلا"
    },
    {
        "start": 3030.34,
        "end": 3041.98,
        "text": "إن هؤلاء يحبون العاجلة ويذرون وراءهم يوما ثقيلا"
    },
    {
        "start": 3041.98,
        "end": 3053.06,
        "text": "نحن خلقناهم وشددنا أسرهم ۖ وإذا شئنا بدلنا أمثالهم تبديلا"
    },
    {
        "start": 3053.06,
        "end": 3063.48,
        "text": "إن هذه تذكرة ۖ فمن شاء اتخذ إلى ربه سبيلا"
    },
    {
        "start": 3063.48,
        "end": 3077.68,
        "text": "وما تشاءون إلا أن يشاء الله ۚ إن الله كان عليما حكيما"
    },
    {
        "start": 3078.32,
        "end": 3093.0,
        "text": "يدخل من يشاء في رحمته ۚ والظالمين أعد لهم عذابا أليما"
    },
    {
        "start": 3078.32,
        "end": 3093.0,
        "text": "بسم الله الرحمن الرحيم والمرسلات عرفا"
    },
    {
        "start": 3093.0,
        "end": 3096.88,
        "text": "فالعاصفات عصفا"
    },
    {
        "start": 3096.88,
        "end": 3101.04,
        "text": "والناشرات نشرا"
    },
    {
        "start": 3101.04,
        "end": 3104.68,
        "text": "فالفارقات فرقا"
    },
    {
        "start": 3105.2,
        "end": 3109.72,
        "text": "فالملقيات ذكرا"
    },
    {
        "start": 3109.72,
        "end": 3113.18,
        "text": "عذرا أو نذرا"
    },
    {
        "start": 3113.18,
        "end": 3117.9,
        "text": "إنما توعدون لواقع"
    },
    {
        "start": 3117.9,
        "end": 3122.18,
        "text": "فإذا النجوم طمست"
    },
    {
        "start": 3122.18,
        "end": 3133.76,
        "text": "وإذا السماء فرجت"
    },
    {
        "start": 3122.18,
        "end": 3133.76,
        "text": "وإذا الجبال نسفت"
    },
    {
        "start": 3122.18,
        "end": 3133.76,
        "text": "وإذا الرسل أقتت"
    },
    {
        "start": 3133.76,
        "end": 3140.0,
        "text": "لأي يوم أجلت"
    },
    {
        "start": 3133.76,
        "end": 3140.0,
        "text": "ليوم الفصل"
    },
    {
        "start": 3140.0,
        "end": 3150.6,
        "text": "وما أدراك ما يوم الفصل"
    },
    {
        "start": 3140.0,
        "end": 3150.6,
        "text": "ويل يومئذ للمكذبين"
    },
    {
        "start": 3150.6,
        "end": 3155.06,
        "text": "ألم نهلك الأولين"
    },
    {
        "start": 3155.06,
        "end": 3159.84,
        "text": "ثم نتبعهم الآخرين"
    },
    {
        "start": 3160.36,
        "end": 3164.68,
        "text": "كذلك نفعل بالمجرمين"
    },
    {
        "start": 3165.32,
        "end": 3170.9,
        "text": "ويل يومئذ للمكذبين"
    },
    {
        "start": 3170.9,
        "end": 3178.14,
        "text": "ألم نخلقكم من ماء مهين"
    },
    {
        "start": 3178.14,
        "end": 3183.78,
        "text": "فجعلناه في قرار مكين"
    },
    {
        "start": 3184.32,
        "end": 3188.32,
        "text": "إلى قدر معلوم"
    },
    {
        "start": 3188.32,
        "end": 3192.66,
        "text": "فقدرنا فنعم القادرون"
    },
    {
        "start": 3193.6,
        "end": 3197.94,
        "text": "ويل يومئذ للمكذبين"
    },
    {
        "start": 3198.72,
        "end": 3202.58,
        "text": "ألم نجعل الأرض كفاتا"
    },
    {
        "start": 3204.94,
        "end": 3207.74,
        "text": "أحياء وأمواتا"
    },
    {
        "start": 3207.74,
        "end": 3226.54,
        "text": "وجعلنا فيها رواسي شامخات وأسقيناكم ماء فراتا"
    },
    {
        "start": 3207.74,
        "end": 3226.54,
        "text": "ويل يومئذ للمكذبين"
    },
    {
        "start": 3226.54,
        "end": 3233.98,
        "text": "انطلقوا إلى ما كنتم به تكذبون"
    },
    {
        "start": 3233.98,
        "end": 3241.58,
        "text": "انطلقوا إلى ظل ذي ثلاث شعب"
    },
    {
        "start": 3241.58,
        "end": 3247.1,
        "text": "لا ظليل ولا يغني من اللهب"
    },
    {
        "start": 3247.1,
        "end": 3252.86,
        "text": "إنها ترمي بشرر كالقصر"
    },
    {
        "start": 3252.86,
        "end": 3265.06,
        "text": "كأنه جمالت صفر"
    },
    {
        "start": 3252.86,
        "end": 3265.06,
        "text": "ويل يومئذ للمكذبين"
    },
    {
        "start": 3265.06,
        "end": 3269.54,
        "text": "هذا يوم لا ينطقون"
    },
    {
        "start": 3269.54,
        "end": 3274.5,
        "text": "ولا يؤذن لهم فيعتذرون"
    },
    {
        "start": 3274.5,
        "end": 3279.88,
        "text": "ويل يومئذ للمكذبين"
    },
    {
        "start": 3279.88,
        "end": 3287.0,
        "text": "هذا يوم الفصل ۖ جمعناكم والأولين"
    },
    {
        "start": 3287.0,
        "end": 3292.88,
        "text": "فإن كان لكم كيد فكيدون"
    },
    {
        "start": 3293.84,
        "end": 3299.24,
        "text": "ويل يومئذ للمكذبين"
    },
    {
        "start": 3299.24,
        "end": 3305.64,
        "text": "إن المتقين في ظلال وعيون"
    },
    {
        "start": 3305.64,
        "end": 3311.02,
        "text": "وفواكه مما يشتهون"
    },
    {
        "start": 3311.02,
        "end": 3319.28,
        "text": "كلوا واشربوا هنيئا بما كنتم تعملون"
    },
    {
        "start": 3319.28,
        "end": 3325.0,
        "text": "إنا كذلك نجزي المحسنين"
    },
    {
        "start": 3325.0,
        "end": 3330.34,
        "text": "ويل يومئذ للمكذبين"
    },
    {
        "start": 3330.34,
        "end": 3338.66,
        "text": "كلوا وتمتعوا قليلا إنكم مجرمون"
    },
    {
        "start": 3338.66,
        "end": 3344.36,
        "text": "ويل يومئذ للمكذبين"
    },
    {
        "start": 3344.36,
        "end": 3350.1,
        "text": "وإذا قيل لهم اركعوا لا يركعون"
    },
    {
        "start": 3350.1,
        "end": 3356.02,
        "text": "ويل يومئذ للمكذبين"
    },
    {
        "start": 3356.02,
        "end": 3362.34,
        "text": "فبأي حديث بعده يؤمنون"
    }
]
[
    {
        "start": 0.0,
        "end": 5.6,
        "text": "۞ قال فما خطبكم أيها المرسلون"
    },
    {
        "start": 5.6,
        "end": 13.96,
        "text": "قالوا إنا أرسلنا إلى قوم مجرمين"
    },
    {
        "start": 13.96,
        "end": 20.88,
        "text": "لنرسل عليهم حجارة من طين"
    },
    {
        "start": 20.88,
        "end": 26.9,
        "text": "مسومة عند ربك للمسرفين"
    },
    {
        "start": 26.9,
        "end": 33.38,
        "text": "فأخرجنا من كان فيها من المؤمنين"
    },
    {
        "start": 33.38,
        "end": 41.06,
        "text": "فما وجدنا فيها غير بيت من المسلمين"
    },
    {
        "start": 41.06,
        "end": 50.7,
        "text": "وتركنا فيها آية للذين يخافون العذاب الأليم"
    },
    {
        "start": 50.7,
        "end": 59.94,
        "text": "وفي موسى إذ أرسلناه إلى فرعون بسلطان مبين"
    },
    {
        "start": 59.94,
        "end": 66.88,
        "text": "فتولى بركنه وقال ساحر أو مجنون"
    },
    {
        "start": 66.88,
        "end": 76.3,
        "text": "فأخذناه وجنوده فنبذناهم في اليم وهو مليم"
    },
    {
        "start": 76.3,
        "end": 83.42,
        "text": "وفي عاد إذ أرسلنا عليهم الريح العقيم"
    },
    {
        "start": 76.3,
        "end": 92.56,
        "text": "ما تذر من شيء أتت عليه إلا جعلته كالرميم"
    },
    {
        "start": 92.56,
        "end": 100.84,
        "text": "وفي ثمود إذ قيل لهم تمتعوا حتى حين"
    },
    {
        "start": 100.84,
        "end": 110.28,
        "text": "فعتوا عن أمر ربهم فأخذتهم الصاعقة وهم ينظرون"
    },
    {
        "start": 110.82,
        "end": 120.22,
        "text": "فما استطاعوا من قيام وما كانوا منتصرين"
    },
    {
        "start": 120.22,
        "end": 129.94,
        "text": "وقوم نوح من قبل ۖ إنهم كانوا قوما فاسقين"
    },
    {
        "start": 129.94,
        "end": 139.12,
        "text": "والسماء بنيناها بأيد وإنا لموسعون"
    },
    {
        "start": 139.12,
        "end": 145.36,
        "text": "والأرض فرشناها فنعم الماهدون"
    },
    {
        "start": 145.36,
        "end": 153.78,
        "text": "ومن كل شيء خلقنا زوجين لعلكم تذكرون"
    },
    {
        "start": 153.78,
        "end": 163.64,
        "text": "ففروا إلى الله ۖ إني لكم منه نذير مبين"
    },
    {
        "start": 163.64,
        "end": 176.32,
        "text": "ولا تجعلوا مع الله إلها آخر ۖ إني لكم منه نذير مبين"
    },
    {
        "start": 176.32,
        "end": 189.84,
        "text": "كذلك ما أتى الذين من قبلهم من رسول إلا قالوا ساحر أو مجنون"
    },
    {
        "start": 189.84,
        "end": 196.58,
        "text": "أتواصوا به ۚ بل هم قوم طاغون"
    },
    {
        "start": 196.58,
        "end": 202.46,
        "text": "فتول عنهم فما أنت بملوم"
    },
    {
        "start": 202.46,
        "end": 210.08,
        "text": "وذكر فإن الذكرى تنفع المؤمنين"
    },
    {
        "start": 210.08,
        "end": 218.32,
        "text": "وما خلقت الجن والإنس إلا ليعبدون"
    },
    {
        "start": 218.32,
        "end": 227.92,
        "text": "ما أريد منهم من رزق وما أريد أن يطعمون"
    },
    {
        "start": 227.92,
        "end": 235.98,
        "text": "إن الله هو الرزاق ذو القوة المتين"
    },
    {
        "start": 235.98,
        "end": 247.36,
        "text": "فإن للذين ظلموا ذنوبا مثل ذنوب أصحابهم فلا يستعجلون"
    },
    {
        "start": 247.36,
        "end": 257.06,
        "text": "فويل للذين كفروا من يومهم الذي يوعدون"
    },
    {
        "start": 247.36,
        "end": 257.06,
        "text": "بسم الله الرحمن الرحيم والطور"
    },
    {
        "start": 257.06,
        "end": 261.16,
        "text": "وكتاب مسطور"
    },
    {
        "start": 261.16,
        "end": 265.4,
        "text": "في رق منشور"
    },
    {
        "start": 265.4,
        "end": 268.28,
        "text": "والبيت المعمور"
    },
    {
        "start": 268.28,
        "end": 271.06,
        "text": "والسقف المرفوع"
    },
    {
        "start": 271.06,
        "end": 273.86,
        "text": "والبحر المسجور"
    },
    {
        "start": 273.86,
        "end": 278.74,
        "text": "إن عذاب ربك لواقع"
    },
    {
        "start": 278.74,
        "end": 282.22,
        "text": "ما له من دافع"
    },
    {
        "start": 282.22,
        "end": 287.36,
        "text": "يوم تمور السماء مورا"
    },
    {
        "start": 287.36,
        "end": 291.38,
        "text": "وتسير الجبال سيرا"
    },
    {
        "start": 291.38,
        "end": 297.04,
        "text": "فويل يومئذ للمكذبين"
    },
    {
        "start": 297.04,
        "end": 302.64,
        "text": "الذين هم في خوض يلعبون"
    },
    {
        "start": 302.64,
        "end": 317.36,
        "text": "يوم يدعون إلى نار جهنم دعا"
    },
    {
        "start": 302.64,
        "end": 317.36,
        "text": "هذه النار التي كنتم بها تكذبون"
    },
    {
        "start": 317.36,
        "end": 324.52,
        "text": "أفسحر هذا أم أنتم لا تبصرون"
    },
    {
        "start": 324.52,
        "end": 339.44,
        "text": "اصلوها فاصبروا أو لا تصبروا سواء عليكم ۖ إنما تجزون ما كنتم تعملون"
    },
    {
        "start": 339.44,
        "end": 347.3,
        "text": "إن المتقين في جنات ونعيم"
    },
    {
        "start": 347.3,
        "end": 356.76,
        "text": "فاكهين بما آتاهم ربهم ووقاهم ربهم عذاب الجحيم"
    },
    {
        "start": 356.76,
        "end": 365.16,
        "text": "كلوا واشربوا هنيئا بما كنتم تعملون"
    },
    {
        "start": 365.16,
        "end": 376.38,
        "text": "متكئين على سرر مصفوفة ۖ وزوجناهم بحور عين"
    },
    {
        "start": 376.38,
        "end": 402.94,
        "text": "والذين آمنوا واتبعتهم ذريتهم بإيمان ألحقنا بهم ذريتهم وما ألتناهم من عملهم من شيء ۚ كل امرئ بما كسب رهين"
    },
    {
        "start": 405.7,
        "end": 413.56,
        "text": "وأمددناهم بفاكهة ولحم مما يشتهون"
    },
    {
        "start": 413.56,
        "end": 422.24,
        "text": "يتنازعون فيها كأسا لا لغو فيها ولا تأثيم"
    },
    {
        "start": 422.24,
        "end": 431.9,
        "text": "۞ ويطوف عليهم غلمان لهم كأنهم لؤلؤ مكنون"
    },
    {
        "start": 431.9,
        "end": 439.76,
        "text": "وأقبل بعضهم على بعض يتساءلون"
    },
    {
        "start": 439.76,
        "end": 448.4,
        "text": "قالوا إنا كنا قبل في أهلنا مشفقين"
    },
    {
        "start": 448.4,
        "end": 467.52,
        "text": "فمن الله علينا ووقانا عذاب السموم"
    },
    {
        "start": 448.4,
        "end": 467.52,
        "text": "إنا كنا من قبل ندعوه ۖ إنه هو البر الرحيم"
    },
    {
        "start": 467.52,
        "end": 476.94,
        "text": "فذكر فما أنت بنعمت ربك بكاهن ولا مجنون"
    },
    {
        "start": 476.94,
        "end": 485.08,
        "text": "أم يقولون شاعر نتربص به ريب المنون"
    },
    {
        "start": 485.08,
        "end": 493.66,
        "text": "قل تربصوا فإني معكم من المتربصين"
    },
    {
        "start": 493.66,
        "end": 503.62,
        "text": "أم تأمرهم أحلامهم بهذا ۚ أم هم قوم طاغون"
    },
    {
        "start": 503.62,
        "end": 510.94,
        "text": "أم يقولون تقوله ۚ بل لا يؤمنون"
    },
    {
        "start": 510.94,
        "end": 519.44,
        "text": "فليأتوا بحديث مثله إن كانوا صادقين"
    },
    {
        "start": 519.44,
        "end": 526.02,
        "text": "أم خلقوا من غير شيء أم هم الخالقون"
    },
    {
        "start": 526.02,
        "end": 533.76,
        "text": "أم خلقوا السماوات والأرض ۚ بل لا يوقنون"
    },
    {
        "start": 533.76,
        "end": 542.5,
        "text": "أم عندهم خزائن ربك أم هم المصيطرون"
    },
    {
        "start": 542.5,
        "end": 554.2,
        "text": "أم لهم سلم يستمعون فيه ۖ فليأت مستمعهم بسلطان مبين"
    },
    {
        "start": 554.2,
        "end": 558.8,
        "text": "أم له البنات ولكم البنون"
    },
    {
        "start": 558.8,
        "end": 568.08,
        "text": "أم تسألهم أجرا فهم من مغرم مثقلون"
    },
    {
        "start": 568.08,
        "end": 573.8,
        "text": "أم عندهم الغيب فهم يكتبون"
    },
    {
        "start": 573.8,
        "end": 582.28,
        "text": "أم يريدون كيدا ۖ فالذين كفروا هم المكيدون"
    },
    {
        "start": 582.28,
        "end": 592.6,
        "text": "أم لهم إله غير الله ۚ سبحان الله عما يشركون"
    },
    {
        "start": 592.6,
        "end": 605.64,
        "text": "وإن يروا كسفا من السماء ساقطا يقولوا سحاب مركوم"
    },
    {
        "start": 605.64,
        "end": 613.6,
        "text": "فذرهم حتى يلاقوا يومهم الذي فيه يصعقون"
    },
    {
        "start": 613.6,
        "end": 623.34,
        "text": "يوم لا يغني عنهم كيدهم شيئا ولا هم ينصرون"
    },
    {
        "start": 623.34,
        "end": 636.08,
        "text": "وإن للذين ظلموا عذابا دون ذلك ولكن أكثرهم لا يعلمون"
    },
    {
        "start": 636.08,
        "end": 647.9,
        "text": "واصبر لحكم ربك فإنك بأعيننا ۖ وسبح بحمد ربك حين تقوم"
    },
    {
        "start": 647.9,
        "end": 658.1,
        "text": "ومن الليل فسبحه وإدبار النجوم"
    },
    {
        "start": 647.9,
        "end": 658.1,
        "text": "بسم الله الرحمن الرحيم والنجم إذا هوى"
    },
    {
        "start": 658.92,
        "end": 663.48,
        "text": "ما ضل صاحبكم وما غوى"
    },
    {
        "start": 663.48,
        "end": 668.28,
        "text": "وما ينطق عن الهوى"
    },
    {
        "start": 668.82,
        "end": 674.08,
        "text": "إن هو إلا وحي يوحى"
    },
    {
        "start": 674.08,
        "end": 678.28,
        "text": "علمه شديد القوى"
    },
    {
        "start": 678.28,
        "end": 682.54,
        "text": "ذو مرة فاستوى"
    },
    {
        "start": 682.54,
        "end": 685.82,
        "text": "وهو بالأفق الأعلى"
    },
    {
        "start": 685.82,
        "end": 690.02,
        "text": "ثم دنا فتدلى"
    },
    {
        "start": 690.02,
        "end": 695.88,
        "text": "فكان قاب قوسين أو أدنى"
    },
    {
        "start": 695.88,
        "end": 701.22,
        "text": "فأوحى إلى عبده ما أوحى"
    },
    {
        "start": 701.22,
        "end": 705.64,
        "text": "ما كذب الفؤاد ما رأى"
    },
    {
        "start": 705.64,
        "end": 710.68,
        "text": "أفتمارونه على ما يرى"
    },
    {
        "start": 710.68,
        "end": 715.1,
        "text": "ولقد رآه نزلة أخرى"
    },
    {
        "start": 715.1,
        "end": 719.58,
        "text": "عند سدرة المنتهى"
    },
    {
        "start": 719.58,
        "end": 725.16,
        "text": "عندها جنة المأوى"
    },
    {
        "start": 725.16,
        "end": 729.14,
        "text": "إذ يغشى السدرة ما يغشى"
    },
    {
        "start": 729.14,
        "end": 733.3,
        "text": "ما زاغ البصر وما طغى"
    },
    {
        "start": 733.3,
        "end": 738.32,
        "text": "لقد رأى من آيات ربه الكبرى"
    },
    {
        "start": 738.32,
        "end": 743.52,
        "text": "أفرأيتم اللات والعزى"
    },
    {
        "start": 743.52,
        "end": 747.5,
        "text": "ومناة الثالثة الأخرى"
    },
    {
        "start": 747.5,
        "end": 752.54,
        "text": "ألكم الذكر وله الأنثى"
    },
    {
        "start": 752.54,
        "end": 757.82,
        "text": "تلك إذا قسمة ضيزى"
    },
    {
        "start": 757.82,
        "end": 790.76,
        "text": "إن هي إلا أسماء سميتموها أنتم وآباؤكم ما أنزل الله بها من سلطان ۚ إن يتبعون إلا الظن وما تهوى الأنفس ۖ ولقد جاءهم من ربهم الهدى"
    },
    {
        "start": 790.76,
        "end": 800.0,
        "text": "أم للإنسان ما تمنى"
    },
    {
        "start": 790.76,
        "end": 800.0,
        "text": "فلله الآخرة والأولى"
    },
    {
        "start": 800.0,
        "end": 820.6,
        "text": "۞ وكم من ملك في السماوات لا تغني شفاعتهم شيئا إلا من بعد أن يأذن الله لمن يشاء ويرضى"
    },
    {
        "start": 820.6,
        "end": 844.24,
        "text": "إن الذين لا يؤمنون بالآخرة ليسمون الملائكة تسمية الأنثى"
    },
    {
        "start": 820.6,
        "end": 868.28,
        "text": "وما لهم به من علم ۖ إن يتبعون إلا الظن ۖ وإن الظن لا يغني من الحق شيئا"
    },
    {
        "start": 844.24,
        "end": 868.28,
        "text": "فأعرض عن من تولى عن ذكرنا ولم يرد إلا الحياة الدنيا"
    },
    {
        "start": 844.24,
        "end": 881.6,
        "text": "ذلك مبلغهم من العلم ۚ إن ربك هو أعلم بمن ضل عن سبيله وهو أعلم بمن اهتدى"
    },
    {
        "start": 881.6,
        "end": 898.9,
        "text": "ولله ما في السماوات وما في الأرض ليجزي الذين أساءوا بما عملوا ويجزي الذين أحسنوا بالحسنى"
    },
    {
        "start": 898.9,
        "end": 939.04,
        "text": "الذين يجتنبون كبائر الإثم والفواحش إلا اللمم ۚ إن ربك واسع المغفرة ۚ هو أعلم بكم إذ أنشأكم من الأرض وإذ أنتم أجنة في بطون أمهاتكم ۖ فلا تزكوا أنفسكم ۖ هو أعلم بمن اتقى"
    },
    {
        "start": 939.04,
        "end": 943.62,
        "text": "أفرأيت الذي تولى"
    },
    {
        "start": 943.62,
        "end": 947.62,
        "text": "وأعطى قليلا وأكدى"
    },
    {
        "start": 947.62,
        "end": 953.22,
        "text": "أعنده علم الغيب فهو يرى"
    },
    {
        "start": 953.22,
        "end": 958.48,
        "text": "أم لم ينبأ بما في صحف موسى"
    },
    {
        "start": 958.48,
        "end": 962.4,
        "text": "وإبراهيم الذي وفى"
    },
    {
        "start": 962.4,
        "end": 968.38,
        "text": "ألا تزر وازرة وزر أخرى"
    },
    {
        "start": 968.38,
        "end": 974.06,
        "text": "وأن ليس للإنسان إلا ما سعى"
    },
    {
        "start": 974.06,
        "end": 978.86,
        "text": "وأن سعيه سوف يرى"
    },
    {
        "start": 978.86,
        "end": 984.72,
        "text": "ثم يجزاه الجزاء الأوفى"
    },
    {
        "start": 984.72,
        "end": 990.58,
        "text": "وأن إلى ربك المنتهى"
    },
    {
        "start": 990.58,
        "end": 995.28,
        "text": "وأنه هو أضحك وأبكى"
    },
    {
        "start": 995.28,
        "end": 999.82,
        "text": "وأنه هو أمات وأحيا"
    },
    {
        "start": 999.82,
        "end": 1007.0,
        "text": "وأنه خلق الزوجين الذكر والأنثى"
    },
    {
        "start": 1007.56,
        "end": 1011.2,
        "text": "من نطفة إذا تمنى"
    },
    {
        "start": 1011.86,
        "end": 1018.0,
        "text": "وأن عليه النشأة الأخرى"
    },
    {
        "start": 1018.6,
        "end": 1022.86,
        "text": "وأنه هو أغنى وأقنى"
    },
    {
        "start": 1022.86,
        "end": 1027.16,
        "text": "وأنه هو رب الشعرى"
    },
    {
        "start": 1027.16,
        "end": 1032.44,
        "text": "وأنه أهلك عادا الأولى"
    },
    {
        "start": 1032.44,
        "end": 1037.0,
        "text": "وثمود فما أبقى"
    },
    {
        "start": 1037.0,
        "end": 1047.44,
        "text": "وقوم نوح من قبل ۖ إنهم كانوا هم أظلم وأطغى"
    },
    {
        "start": 1047.44,
        "end": 1051.0,
        "text": "والمؤتفكة أهوى"
    },
    {
        "start": 1051.0,
        "end": 1054.84,
        "text": "فغشاها ما غشى"
    },
    {
        "start": 1054.84,
        "end": 1060.6,
        "text": "فبأي آلاء ربك تتمارى"
    },
    {
        "start": 1061.14,
        "end": 1067.2,
        "text": "هذا نذير من النذر الأولى"
    },
    {
        "start": 1067.84,
        "end": 1070.28,
        "text": "أزفت الآزفة"
    },
    {
        "start": 1070.28,
        "end": 1075.88,
        "text": "ليس لها من دون الله كاشفة"
    },
    {
        "start": 1075.88,
        "end": 1082.06,
        "text": "أفمن هذا الحديث تعجبون"
    },
    {
        "start": 1082.06,
        "end": 1086.28,
        "text": "وتضحكون ولا تبكون"
    },
    {
        "start": 1086.28,
        "end": 1089.78,
        "text": "وأنتم سامدون"
    },
    {
        "start": 1089.78,
        "end": 1093.76,
        "text": "فاسجدوا لله واعبدوا ۩"
    },
    {
        "start": 1093.76,
        "end": 1098.74,
        "text": "بسم الله الرحمن الرحيم اقتربت الساعة وانشق القمر"
    },
    {
        "start": 1098.74,
        "end": 1108.48,
        "text": "وإن يروا آية يعرضوا ويقولوا سحر مستمر"
    },
    {
        "start": 1108.48,
        "end": 1118.62,
        "text": "وكذبوا واتبعوا أهواءهم ۚ وكل أمر مستقر"
    },
    {
        "start": 1118.62,
        "end": 1128.52,
        "text": "ولقد جاءهم من الأنباء ما فيه مزدجر"
    },
    {
        "start": 1128.52,
        "end": 1135.92,
        "text": "حكمة بالغة ۖ فما تغن النذر"
    },
    {
        "start": 1135.92,
        "end": 1144.62,
        "text": "فتول عنهم ۘ يوم يدع الداع إلى شيء نكر"
    },
    {
        "start": 1144.62,
        "end": 1156.8,
        "text": "خشعا أبصارهم يخرجون من الأجداث كأنهم جراد منتشر"
    },
    {
        "start": 1156.8,
        "end": 1166.12,
        "text": "مهطعين إلى الداع ۖ يقول الكافرون هذا يوم عسر"
    },
    {
        "start": 1166.12,
        "end": 1178.22,
        "text": "۞ كذبت قبلهم قوم نوح فكذبوا عبدنا وقالوا مجنون وازدجر"
    },
    {
        "start": 1178.22,
        "end": 1186.12,
        "text": "فدعا ربه أني مغلوب فانتصر"
    },
    {
        "start": 1186.12,
        "end": 1195.14,
        "text": "ففتحنا أبواب السماء بماء منهمر"
    },
    {
        "start": 1195.14,
        "end": 1205.72,
        "text": "وفجرنا الأرض عيونا فالتقى الماء على أمر قد قدر"
    },
    {
        "start": 1205.72,
        "end": 1220.58,
        "text": "وحملناه على ذات ألواح ودسر"
    },
    {
        "start": 1205.72,
        "end": 1220.58,
        "text": "تجري بأعيننا جزاء لمن كان كفر"
    },
    {
        "start": 1220.58,
        "end": 1228.4,
        "text": "ولقد تركناها آية فهل من مدكر"
    },
    {
        "start": 1228.4,
        "end": 1232.78,
        "text": "فكيف كان عذابي ونذر"
    },
    {
        "start": 1232.78,
        "end": 1240.44,
        "text": "ولقد يسرنا القرآن للذكر فهل من مدكر"
    },
    {
        "start": 1240.44,
        "end": 1247.86,
        "text": "كذبت عاد فكيف كان عذابي ونذر"
    },
    {
        "start": 1247.86,
        "end": 1259.64,
        "text": "إنا أرسلنا عليهم ريحا صرصرا في يوم نحس مستمر"
    },
    {
        "start": 1259.64,
        "end": 1270.0,
        "text": "تنزع الناس كأنهم أعجاز نخل منقعر"
    },
    {
        "start": 1270.0,
        "end": 1274.08,
        "text": "فكيف كان عذابي ونذر"
    },
    {
        "start": 1274.08,
        "end": 1282.16,
        "text": "ولقد يسرنا القرآن للذكر فهل من مدكر"
    },
    {
        "start": 1282.16,
        "end": 1286.42,
        "text": "كذبت ثمود بالنذر"
    },
    {
        "start": 1286.42,
        "end": 1300.78,
        "text": "فقالوا أبشرا منا واحدا نتبعه إنا إذا لفي ضلال وسعر"
    },
    {
        "start": 1300.78,
        "end": 1309.4,
        "text": "أألقي الذكر عليه من بيننا بل هو كذاب أشر"
    },
    {
        "start": 1309.4,
        "end": 1316.14,
        "text": "سيعلمون غدا من الكذاب الأشر"
    },
    {
        "start": 1316.14,
        "end": 1325.42,
        "text": "إنا مرسلو الناقة فتنة لهم فارتقبهم واصطبر"
    },
    {
        "start": 1325.42,
        "end": 1337.5,
        "text": "ونبئهم أن الماء قسمة بينهم ۖ كل شرب محتضر"
    },
    {
        "start": 1337.5,
        "end": 1342.68,
        "text": "فنادوا صاحبهم فتعاطى فعقر"
    },
    {
        "start": 1342.68,
        "end": 1347.08,
        "text": "فكيف كان عذابي ونذر"
    },
    {
        "start": 1347.08,
        "end": 1360.2,
        "text": "إنا أرسلنا عليهم صيحة واحدة فكانوا كهشيم المحتظر"
    },
    {
        "start": 1360.2,
        "end": 1367.6,
        "text": "ولقد يسرنا القرآن للذكر فهل من مدكر"
    },
    {
        "start": 1367.6,
        "end": 1373.32,
        "text": "كذبت قوم لوط بالنذر"
    },
    {
        "start": 1373.32,
        "end": 1395.3,
        "text": "إنا أرسلنا عليهم حاصبا إلا آل لوط ۖ نجيناهم بسحر"
    },
    {
        "start": 1373.32,
        "end": 1395.3,
        "text": "نعمة من عندنا ۚ كذلك نجزي من شكر"
    },
    {
        "start": 1395.3,
        "end": 1403.84,
        "text": "ولقد أنذرهم بطشتنا فتماروا بالنذر"
    },
    {
        "start": 1403.84,
        "end": 1415.24,
        "text": "ولقد راودوه عن ضيفه فطمسنا أعينهم فذوقوا عذابي ونذر"
    },
    {
        "start": 1415.24,
        "end": 1423.18,
        "text": "ولقد صبحهم بكرة عذاب مستقر"
    },
    {
        "start": 1423.18,
        "end": 1427.2,
        "text": "فذوقوا عذابي ونذر"
    },
    {
        "start": 1427.2,
        "end": 1435.2,
        "text": "ولقد يسرنا القرآن للذكر فهل من مدكر"
    },
    {
        "start": 1435.2,
        "end": 1440.84,
        "text": "ولقد جاء آل فرعون النذر"
    },
    {
        "start": 1440.84,
        "end": 1451.14,
        "text": "كذبوا بآياتنا كلها فأخذناهم أخذ عزيز مقتدر"
    },
    {
        "start": 1451.14,
        "end": 1462.46,
        "text": "أكفاركم خير من أولئكم أم لكم براءة في الزبر"
    },
    {
        "start": 1462.46,
        "end": 1471.12,
        "text": "أم يقولون نحن جميع منتصر"
    },
    {
        "start": 1471.12,
        "end": 1476.32,
        "text": "سيهزم الجمع ويولون الدبر"
    },
    {
        "start": 1476.32,
        "end": 1483.22,
        "text": "بل الساعة موعدهم والساعة أدهى وأمر"
    },
    {
        "start": 1483.22,
        "end": 1490.04,
        "text": "إن المجرمين في ضلال وسعر"
    },
    {
        "start": 1490.04,
        "end": 1499.02,
        "text": "يوم يسحبون في النار على وجوههم ذوقوا مس سقر"
    },
    {
        "start": 1499.02,
        "end": 1505.48,
        "text": "إنا كل شيء خلقناه بقدر"
    },
    {
        "start": 1505.48,
        "end": 1513.84,
        "text": "وما أمرنا إلا واحدة كلمح بالبصر"
    },
    {
        "start": 1513.84,
        "end": 1521.74,
        "text": "ولقد أهلكنا أشياعكم فهل من مدكر"
    },
    {
        "start": 1521.74,
        "end": 1527.5,
        "text": "وكل شيء فعلوه في الزبر"
    },
    {
        "start": 1527.5,
        "end": 1533.56,
        "text": "وكل صغير وكبير مستطر"
    },
    {
        "start": 1533.56,
        "end": 1541.46,
        "text": "إن المتقين في جنات ونهر"
    },
    {
        "start": 1541.46,
        "end": 1549.84,
        "text": "في مقعد صدق عند مليك مقتدر"
    },
    {
        "start": 1549.84,
        "end": 1558.56,
        "text": "بسم الله الرحمن الرحيم الرحمن"
    },
    {
        "start": 1553.7,
        "end": 1558.56,
        "text": "علم القرآن"
    },
    {
        "start": 1558.56,
        "end": 1562.68,
        "text": "خلق الإنسان"
    },
    {
        "start": 1562.68,
        "end": 1565.94,
        "text": "علمه البيان"
    },
    {
        "start": 1565.94,
        "end": 1570.32,
        "text": "الشمس والقمر بحسبان"
    },
    {
        "start": 1570.32,
        "end": 1575.6,
        "text": "والنجم والشجر يسجدان"
    },
    {
        "start": 1575.6,
        "end": 1582.18,
        "text": "والسماء رفعها ووضع الميزان"
    },
    {
        "start": 1582.18,
        "end": 1586.72,
        "text": "ألا تطغوا في الميزان"
    },
    {
        "start": 1586.72,
        "end": 1593.88,
        "text": "وأقيموا الوزن بالقسط ولا تخسروا الميزان"
    },
    {
        "start": 1593.88,
        "end": 1598.76,
        "text": "والأرض وضعها للأنام"
    },
    {
        "start": 1598.76,
        "end": 1606.8,
        "text": "فيها فاكهة والنخل ذات الأكمام"
    },
    {
        "start": 1606.8,
        "end": 1611.34,
        "text": "والحب ذو العصف والريحان"
    },
    {
        "start": 1611.34,
        "end": 1618.36,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1618.36,
        "end": 1626.46,
        "text": "خلق الإنسان من صلصال كالفخار"
    },
    {
        "start": 1626.46,
        "end": 1637.16,
        "text": "وخلق الجان من مارج من نار"
    },
    {
        "start": 1637.16,
        "end": 1644.5,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1644.5,
        "end": 1649.54,
        "text": "رب المشرقين ورب المغربين"
    },
    {
        "start": 1649.54,
        "end": 1656.48,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1656.48,
        "end": 1661.26,
        "text": "مرج البحرين يلتقيان"
    },
    {
        "start": 1661.26,
        "end": 1666.9,
        "text": "بينهما برزخ لا يبغيان"
    },
    {
        "start": 1666.9,
        "end": 1673.54,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1673.54,
        "end": 1679.54,
        "text": "يخرج منهما اللؤلؤ والمرجان"
    },
    {
        "start": 1680.1,
        "end": 1686.54,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1687.16,
        "end": 1694.28,
        "text": "وله الجوار المنشآت في البحر كالأعلام"
    },
    {
        "start": 1694.28,
        "end": 1701.76,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1701.76,
        "end": 1705.82,
        "text": "كل من عليها فان"
    },
    {
        "start": 1705.82,
        "end": 1712.74,
        "text": "ويبقى وجه ربك ذو الجلال والإكرام"
    },
    {
        "start": 1712.74,
        "end": 1719.52,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1719.52,
        "end": 1730.0,
        "text": "يسأله من في السماوات والأرض ۚ كل يوم هو في شأن"
    },
    {
        "start": 1730.0,
        "end": 1737.14,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1737.14,
        "end": 1742.26,
        "text": "سنفرغ لكم أيه الثقلان"
    },
    {
        "start": 1742.26,
        "end": 1749.28,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1749.28,
        "end": 1771.6,
        "text": "يا معشر الجن والإنس إن استطعتم أن تنفذوا من أقطار السماوات والأرض فانفذوا ۚ لا تنفذون إلا بسلطان"
    },
    {
        "start": 1771.6,
        "end": 1778.44,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1778.44,
        "end": 1791.48,
        "text": "يرسل عليكما شواظ من نار ونحاس فلا تنتصران"
    },
    {
        "start": 1791.48,
        "end": 1798.38,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1798.38,
        "end": 1807.3,
        "text": "فإذا انشقت السماء فكانت وردة كالدهان"
    },
    {
        "start": 1807.3,
        "end": 1814.76,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1814.76,
        "end": 1827.44,
        "text": "فيومئذ لا يسأل عن ذنبه إنس ولا جان"
    },
    {
        "start": 1827.44,
        "end": 1834.78,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1834.78,
        "end": 1845.0,
        "text": "يعرف المجرمون بسيماهم فيؤخذ بالنواصي والأقدام"
    },
    {
        "start": 1845.0,
        "end": 1852.4,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1852.4,
        "end": 1865.9,
        "text": "هذه جهنم التي يكذب بها المجرمون"
    },
    {
        "start": 1852.4,
        "end": 1865.9,
        "text": "يطوفون بينها وبين حميم آن"
    },
    {
        "start": 1865.9,
        "end": 1872.86,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1872.86,
        "end": 1879.0,
        "text": "ولمن خاف مقام ربه جنتان"
    },
    {
        "start": 1879.0,
        "end": 1890.28,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1886.72,
        "end": 1890.28,
        "text": "ذواتا أفنان"
    },
    {
        "start": 1890.28,
        "end": 1897.16,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1897.7,
        "end": 1901.9,
        "text": "فيهما عينان تجريان"
    },
    {
        "start": 1901.9,
        "end": 1908.84,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1908.84,
        "end": 1916.38,
        "text": "فيهما من كل فاكهة زوجان"
    },
    {
        "start": 1916.38,
        "end": 1922.92,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1923.44,
        "end": 1936.36,
        "text": "متكئين على فرش بطائنها من إستبرق ۚ وجنى الجنتين دان"
    },
    {
        "start": 1936.36,
        "end": 1943.32,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1943.32,
        "end": 1958.92,
        "text": "فيهن قاصرات الطرف لم يطمثهن إنس قبلهم ولا جان"
    },
    {
        "start": 1958.92,
        "end": 1973.34,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1966.36,
        "end": 1973.34,
        "text": "كأنهن الياقوت والمرجان"
    },
    {
        "start": 1973.34,
        "end": 1980.84,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1980.84,
        "end": 1987.22,
        "text": "هل جزاء الإحسان إلا الإحسان"
    },
    {
        "start": 1987.22,
        "end": 1994.44,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 1994.44,
        "end": 1999.94,
        "text": "ومن دونهما جنتان"
    },
    {
        "start": 1999.94,
        "end": 2007.04,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 2007.04,
        "end": 2012.22,
        "text": "مدهامتان"
    },
    {
        "start": 2012.22,
        "end": 2026.66,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 2019.9,
        "end": 2026.66,
        "text": "فيهما عينان نضاختان"
    },
    {
        "start": 2026.66,
        "end": 2040.78,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 2034.26,
        "end": 2040.78,
        "text": "فيهما فاكهة ونخل ورمان"
    },
    {
        "start": 2040.78,
        "end": 2054.08,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 2049.16,
        "end": 2054.08,
        "text": "فيهن خيرات حسان"
    },
    {
        "start": 2054.08,
        "end": 2060.86,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 2061.9,
        "end": 2067.3,
        "text": "حور مقصورات في الخيام"
    },
    {
        "start": 2067.3,
        "end": 2074.36,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 2074.36,
        "end": 2085.24,
        "text": "لم يطمثهن إنس قبلهم ولا جان"
    },
    {
        "start": 2085.24,
        "end": 2092.54,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 2092.54,
        "end": 2101.4,
        "text": "متكئين على رفرف خضر وعبقري حسان"
    },
    {
        "start": 2101.4,
        "end": 2108.92,
        "text": "فبأي آلاء ربكما تكذبان"
    },
    {
        "start": 2108.92,
        "end": 2117.92,
        "text": "تبارك اسم ربك ذي الجلال والإكرام"
    },
    {
        "start": 2108.92,
        "end": 2117.92,
        "text": "بسم الله الرحمن الرحيم إذا وقعت الواقعة"
    },
    {
        "start": 2117.92,
        "end": 2122.32,
        "text": "ليس لوقعتها كاذبة"
    },
    {
        "start": 2122.32,
        "end": 2125.7,
        "text": "خافضة رافعة"
    },
    {
        "start": 2125.7,
        "end": 2130.22,
        "text": "إذا رجت الأرض رجا"
    },
    {
        "start": 2130.22,
        "end": 2134.34,
        "text": "وبست الجبال بسا"
    },
    {
        "start": 2134.34,
        "end": 2141.0,
        "text": "فكانت هباء منبثا"
    },
    {
        "start": 2141.0,
        "end": 2146.72,
        "text": "وكنتم أزواجا ثلاثة"
    },
    {
        "start": 2146.72,
        "end": 2153.82,
        "text": "فأصحاب الميمنة ما أصحاب الميمنة"
    },
    {
        "start": 2153.82,
        "end": 2160.98,
        "text": "وأصحاب المشأمة ما أصحاب المشأمة"
    },
    {
        "start": 2160.98,
        "end": 2165.48,
        "text": "والسابقون السابقون"
    },
    {
        "start": 2166.14,
        "end": 2169.98,
        "text": "أولئك المقربون"
    },
    {
        "start": 2170.64,
        "end": 2175.36,
        "text": "في جنات النعيم"
    },
    {
        "start": 2175.36,
        "end": 2179.84,
        "text": "ثلة من الأولين"
    },
    {
        "start": 2179.84,
        "end": 2184.6,
        "text": "وقليل من الآخرين"
    },
    {
        "start": 2184.6,
        "end": 2194.74,
        "text": "على سرر موضونة"
    },
    {
        "start": 2184.6,
        "end": 2194.74,
        "text": "متكئين عليها متقابلين"
    },
    {
        "start": 2194.74,
        "end": 2200.66,
        "text": "يطوف عليهم ولدان مخلدون"
    },
    {
        "start": 2200.66,
        "end": 2208.88,
        "text": "بأكواب وأباريق وكأس من معين"
    },
    {
        "start": 2208.88,
        "end": 2215.62,
        "text": "لا يصدعون عنها ولا ينزفون"
    },
    {
        "start": 2215.62,
        "end": 2222.36,
        "text": "وفاكهة مما يتخيرون"
    },
    {
        "start": 2222.36,
        "end": 2228.42,
        "text": "ولحم طير مما يشتهون"
    },
    {
        "start": 2228.42,
        "end": 2235.98,
        "text": "وحور عين"
    },
    {
        "start": 2228.42,
        "end": 2235.98,
        "text": "كأمثال اللؤلؤ المكنون"
    },
    {
        "start": 2237.42,
        "end": 2242.82,
        "text": "جزاء بما كانوا يعملون"
    },
    {
        "start": 2242.82,
        "end": 2250.12,
        "text": "لا يسمعون فيها لغوا ولا تأثيما"
    },
    {
        "start": 2250.12,
        "end": 2256.68,
        "text": "إلا قيلا سلاما سلاما"
    },
    {
        "start": 2257.24,
        "end": 2264.32,
        "text": "وأصحاب اليمين ما أصحاب اليمين"
    },
    {
        "start": 2264.32,
        "end": 2268.32,
        "text": "في سدر مخضود"
    },
    {
        "start": 2268.32,
        "end": 2272.74,
        "text": "وطلح منضود"
    },
    {
        "start": 2272.74,
        "end": 2276.6,
        "text": "وظل ممدود"
    },
    {
        "start": 2276.6,
        "end": 2281.18,
        "text": "وماء مسكوب"
    },
    {
        "start": 2281.18,
        "end": 2285.16,
        "text": "وفاكهة كثيرة"
    },
    {
        "start": 2285.16,
        "end": 2291.44,
        "text": "لا مقطوعة ولا ممنوعة"
    },
    {
        "start": 2291.44,
        "end": 2295.34,
        "text": "وفرش مرفوعة"
    },
    {
        "start": 2295.34,
        "end": 2302.6,
        "text": "إنا أنشأناهن إنشاء"
    },
    {
        "start": 2305.52,
        "end": 2308.32,
        "text": "فجعلناهن أبكارا"
    },
    {
        "start": 2308.32,
        "end": 2311.92,
        "text": "عربا أترابا"
    },
    {
        "start": 2311.92,
        "end": 2315.2,
        "text": "لأصحاب اليمين"
    },
    {
        "start": 2315.2,
        "end": 2319.46,
        "text": "ثلة من الأولين"
    },
    {
        "start": 2319.46,
        "end": 2324.4,
        "text": "وثلة من الآخرين"
    },
    {
        "start": 2324.4,
        "end": 2331.7,
        "text": "وأصحاب الشمال ما أصحاب الشمال"
    },
    {
        "start": 2331.7,
        "end": 2335.74,
        "text": "في سموم وحميم"
    },
    {
        "start": 2335.74,
        "end": 2340.02,
        "text": "وظل من يحموم"
    },
    {
        "start": 2340.02,
        "end": 2345.14,
        "text": "لا بارد ولا كريم"
    },
    {
        "start": 2345.14,
        "end": 2351.76,
        "text": "إنهم كانوا قبل ذلك مترفين"
    },
    {
        "start": 2351.76,
        "end": 2357.86,
        "text": "وكانوا يصرون على الحنث العظيم"
    },
    {
        "start": 2357.86,
        "end": 2371.84,
        "text": "وكانوا يقولون أئذا متنا وكنا ترابا وعظاما أإنا لمبعوثون"
    },
    {
        "start": 2371.84,
        "end": 2377.1,
        "text": "أوآباؤنا الأولون"
    },
    {
        "start": 2377.1,
        "end": 2383.96,
        "text": "قل إن الأولين والآخرين"
    },
    {
        "start": 2383.96,
        "end": 2391.62,
        "text": "لمجموعون إلى ميقات يوم معلوم"
    },
    {
        "start": 2391.62,
        "end": 2401.04,
        "text": "ثم إنكم أيها الضالون المكذبون"
    },
    {
        "start": 2401.04,
        "end": 2408.4,
        "text": "لآكلون من شجر من زقوم"
    },
    {
        "start": 2408.4,
        "end": 2413.16,
        "text": "فمالئون منها البطون"
    },
    {
        "start": 2413.16,
        "end": 2418.14,
        "text": "فشاربون عليه من الحميم"
    },
    {
        "start": 2418.14,
        "end": 2422.12,
        "text": "فشاربون شرب الهيم"
    },
    {
        "start": 2422.12,
        "end": 2426.94,
        "text": "هذا نزلهم يوم الدين"
    },
    {
        "start": 2426.94,
        "end": 2433.0,
        "text": "نحن خلقناكم فلولا تصدقون"
    },
    {
        "start": 2433.0,
        "end": 2438.24,
        "text": "أفرأيتم ما تمنون"
    },
    {
        "start": 2438.24,
        "end": 2445.38,
        "text": "أأنتم تخلقونه أم نحن الخالقون"
    },
    {
        "start": 2445.38,
        "end": 2453.86,
        "text": "نحن قدرنا بينكم الموت وما نحن بمسبوقين"
    },
    {
        "start": 2453.86,
        "end": 2464.04,
        "text": "على أن نبدل أمثالكم وننشئكم في ما لا تعلمون"
    },
    {
        "start": 2464.04,
        "end": 2473.84,
        "text": "ولقد علمتم النشأة الأولى فلولا تذكرون"
    },
    {
        "start": 2473.84,
        "end": 2478.6,
        "text": "أفرأيتم ما تحرثون"
    },
    {
        "start": 2478.6,
        "end": 2486.32,
        "text": "أأنتم تزرعونه أم نحن الزارعون"
    },
    {
        "start": 2486.32,
        "end": 2495.88,
        "text": "لو نشاء لجعلناه حطاما فظلتم تفكهون"
    },
    {
        "start": 2495.88,
        "end": 2500.08,
        "text": "إنا لمغرمون"
    },
    {
        "start": 2500.08,
        "end": 2503.76,
        "text": "بل نحن محرومون"
    },
    {
        "start": 2503.76,
        "end": 2510.14,
        "text": "أفرأيتم الماء الذي تشربون"
    },
    {
        "start": 2510.14,
        "end": 2519.8,
        "text": "أأنتم أنزلتموه من المزن أم نحن المنزلون"
    },
    {
        "start": 2519.8,
        "end": 2528.34,
        "text": "لو نشاء جعلناه أجاجا فلولا تشكرون"
    },
    {
        "start": 2528.34,
        "end": 2534.58,
        "text": "أفرأيتم النار التي تورون"
    },
    {
        "start": 2534.58,
        "end": 2544.34,
        "text": "أأنتم أنشأتم شجرتها أم نحن المنشئون"
    },
    {
        "start": 2544.34,
        "end": 2552.84,
        "text": "نحن جعلناها تذكرة ومتاعا للمقوين"
    },
    {
        "start": 2552.84,
        "end": 2557.5,
        "text": "فسبح باسم ربك العظيم"
    },
    {
        "start": 2557.5,
        "end": 2564.34,
        "text": "۞ فلا أقسم بمواقع النجوم"
    },
    {
        "start": 2564.34,
        "end": 2571.3,
        "text": "وإنه لقسم لو تعلمون عظيم"
    },
    {
        "start": 2571.3,
        "end": 2576.8,
        "text": "إنه لقرآن كريم"
    },
    {
        "start": 2576.8,
        "end": 2580.76,
        "text": "في كتاب مكنون"
    },
    {
        "start": 2580.76,
        "end": 2585.78,
        "text": "لا يمسه إلا المطهرون"
    },
    {
        "start": 2585.78,
        "end": 2591.96,
        "text": "تنزيل من رب العالمين"
    },
    {
        "start": 2591.96,
        "end": 2599.24,
        "text": "أفبهذا الحديث أنتم مدهنون"
    },
    {
        "start": 2599.24,
        "end": 2606.44,
        "text": "وتجعلون رزقكم أنكم تكذبون"
    },
    {
        "start": 2606.44,
        "end": 2611.36,
        "text": "فلولا إذا بلغت الحلقوم"
    },
    {
        "start": 2611.36,
        "end": 2618.58,
        "text": "وأنتم حينئذ تنظرون"
    },
    {
        "start": 2618.58,
        "end": 2626.36,
        "text": "ونحن أقرب إليه منكم ولكن لا تبصرون"
    },
    {
        "start": 2626.9,
        "end": 2632.96,
        "text": "فلولا إن كنتم غير مدينين"
    },
    {
        "start": 2633.48,
        "end": 2639.64,
        "text": "ترجعونها إن كنتم صادقين"
    },
    {
        "start": 2639.64,
        "end": 2646.16,
        "text": "فأما إن كان من المقربين"
    },
    {
        "start": 2646.16,
        "end": 2653.9,
        "text": "فروح وريحان وجنت نعيم"
    },
    {
        "start": 2653.9,
        "end": 2661.24,
        "text": "وأما إن كان من أصحاب اليمين"
    },
    {
        "start": 2661.24,
        "end": 2666.26,
        "text": "فسلام لك من أصحاب اليمين"
    },
    {
        "start": 2666.26,
        "end": 2677.5,
        "text": "وأما إن كان من المكذبين الضالين"
    },
    {
        "start": 2677.5,
        "end": 2681.22,
        "text": "فنزل من حميم"
    },
    {
        "start": 2681.22,
        "end": 2684.58,
        "text": "وتصلية جحيم"
    },
    {
        "start": 2684.58,
        "end": 2689.98,
        "text": "إن هذا لهو حق اليقين"
    },
    {
        "start": 2689.98,
        "end": 2703.0,
        "text": "فسبح باسم ربك العظيم"
    },
    {
        "start": 2689.98,
        "end": 2703.0,
        "text": "بسم الله الرحمن الرحيم سبح لله ما في السماوات والأرض ۖ وهو العزيز الحكيم"
    },
    {
        "start": 2703.0,
        "end": 2715.82,
        "text": "له ملك السماوات والأرض ۖ يحيي ويميت ۖ وهو على كل شيء قدير"
    },
    {
        "start": 2715.82,
        "end": 2727.12,
        "text": "هو الأول والآخر والظاهر والباطن ۖ وهو بكل شيء عليم"
    },
    {
        "start": 2727.12,
        "end": 2764.42,
        "text": "هو الذي خلق السماوات والأرض في ستة أيام ثم استوى على العرش ۚ يعلم ما يلج في الأرض وما يخرج منها وما ينزل من السماء وما يعرج فيها ۖ وهو معكم أين ما كنتم ۚ والله بما تعملون بصير"
    },
    {
        "start": 2764.42,
        "end": 2774.54,
        "text": "له ملك السماوات والأرض ۚ وإلى الله ترجع الأمور"
    },
    {
        "start": 2774.54,
        "end": 2789.0,
        "text": "يولج الليل في النهار ويولج النهار في الليل ۚ وهو عليم بذات الصدور"
    },
    {
        "start": 2789.0,
        "end": 2812.3,
        "text": "آمنوا بالله ورسوله وأنفقوا مما جعلكم مستخلفين فيه ۖ فالذين آمنوا منكم وأنفقوا لهم أجر كبير"
    },
    {
        "start": 2812.3,
        "end": 2831.44,
        "text": "وما لكم لا تؤمنون بالله ۙ والرسول يدعوكم لتؤمنوا بربكم وقد أخذ ميثاقكم إن كنتم مؤمنين"
    },
    {
        "start": 2831.44,
        "end": 2853.0,
        "text": "هو الذي ينزل على عبده آيات بينات ليخرجكم من الظلمات إلى النور ۚ وإن الله بكم لرءوف رحيم"
    },
    {
        "start": 2853.0,
        "end": 2899.48,
        "text": "وما لكم ألا تنفقوا في سبيل الله ولله ميراث السماوات والأرض ۚ لا يستوي منكم من أنفق من قبل الفتح وقاتل ۚ أولئك أعظم درجة من الذين أنفقوا من بعد وقاتلوا ۚ وكلا وعد الله الحسنى ۚ والله بما تعملون خبير"
    },
    {
        "start": 2899.48,
        "end": 2912.68,
        "text": "من ذا الذي يقرض الله قرضا حسنا فيضاعفه له وله أجر كريم"
    },
    {
        "start": 2912.68,
        "end": 2941.34,
        "text": "يوم ترى المؤمنين والمؤمنات يسعى نورهم بين أيديهم وبأيمانهم بشراكم اليوم جنات تجري من تحتها الأنهار خالدين فيها ۚ ذلك هو الفوز العظيم"
    },
    {
        "start": 2941.34,
        "end": 2982.14,
        "text": "يوم يقول المنافقون والمنافقات للذين آمنوا انظرونا نقتبس من نوركم قيل ارجعوا وراءكم فالتمسوا نورا فضرب بينهم بسور له باب باطنه فيه الرحمة وظاهره من قبله العذاب"
    },
    {
        "start": 2962.1,
        "end": 3017.6,
        "text": "ينادونهم ألم نكن معكم ۖ قالوا بلى ولكنكم فتنتم أنفسكم وتربصتم وارتبتم وغرتكم الأماني حتى جاء أمر الله وغركم بالله الغرور"
    },
    {
        "start": 3017.6,
        "end": 3035.46,
        "text": "فاليوم لا يؤخذ منكم فدية ولا من الذين كفروا ۚ مأواكم النار ۖ هي مولاكم ۖ وبئس المصير"
    },
    {
        "start": 3035.46,
        "end": 3069.18,
        "text": "۞ ألم يأن للذين آمنوا أن تخشع قلوبهم لذكر الله وما نزل من الحق ولا يكونوا كالذين أوتوا الكتاب من قبل فطال عليهم الأمد فقست قلوبهم ۖ وكثير منهم فاسقون"
    },
    {
        "start": 3069.18,
        "end": 3084.64,
        "text": "اعلموا أن الله يحيي الأرض بعد موتها ۚ قد بينا لكم الآيات لعلكم تعقلون"
    },
    {
        "start": 3084.64,
        "end": 3101.06,
        "text": "إن المصدقين والمصدقات وأقرضوا الله قرضا حسنا يضاعف لهم ولهم أجر كريم"
    },
    {
        "start": 3101.06,
        "end": 3129.02,
        "text": "والذين آمنوا بالله ورسله أولئك هم الصديقون ۖ والشهداء عند ربهم لهم أجرهم ونورهم ۖ والذين كفروا وكذبوا بآياتنا أولئك أصحاب الجحيم"
    },
    {
        "start": 3129.02,
        "end": 3190.02,
        "text": "اعلموا أنما الحياة الدنيا لعب ولهو وزينة وتفاخر بينكم وتكاثر في الأموال والأولاد ۖ كمثل غيث أعجب الكفار نباته ثم يهيج فتراه مصفرا ثم يكون حطاما ۖ وفي الآخرة عذاب شديد ومغفرة من الله ورضوان ۚ وما الحياة الدنيا إلا متاع الغرور"
    },
    {
        "start": 3190.02,
        "end": 3222.66,
        "text": "سابقوا إلى مغفرة من ربكم وجنة عرضها كعرض السماء والأرض أعدت للذين آمنوا بالله ورسله ۚ ذلك فضل الله يؤتيه من يشاء ۚ والله ذو الفضل العظيم"
    },
    {
        "start": 3222.66,
        "end": 3245.68,
        "text": "ما أصاب من مصيبة في الأرض ولا في أنفسكم إلا في كتاب من قبل أن نبرأها ۚ إن ذلك على الله يسير"
    },
    {
        "start": 3245.68,
        "end": 3262.22,
        "text": "لكيلا تأسوا على ما فاتكم ولا تفرحوا بما آتاكم ۗ والله لا يحب كل مختال فخور"
    },
    {
        "start": 3262.22,
        "end": 3279.72,
        "text": "الذين يبخلون ويأمرون الناس بالبخل ۗ ومن يتول فإن الله هو الغني الحميد"
    },
    {
        "start": 3279.72,
        "end": 3320.24,
        "text": "لقد أرسلنا رسلنا بالبينات وأنزلنا معهم الكتاب والميزان ليقوم الناس بالقسط ۖ وأنزلنا الحديد فيه بأس شديد ومنافع للناس وليعلم الله من ينصره ورسله بالغيب ۚ إن الله قوي عزيز"
    },
    {
        "start": 3320.24,
        "end": 3341.8,
        "text": "ولقد أرسلنا نوحا وإبراهيم وجعلنا في ذريتهما النبوة والكتاب ۖ فمنهم مهتد ۖ وكثير منهم فاسقون"
    },
    {
        "start": 3341.8,
        "end": 3397.1,
        "text": "ثم قفينا على آثارهم برسلنا وقفينا بعيسى ابن مريم وآتيناه الإنجيل وجعلنا في قلوب الذين اتبعوه رأفة ورحمة ورهبانية ابتدعوها ما كتبناها عليهم إلا ابتغاء رضوان الله فما رعوها حق رعايتها ۖ فآتينا الذين آمنوا منهم أجرهم ۖ وكثير منهم فاسقون"
    },
    {
        "start": 3397.1,
        "end": 3422.1,
        "text": "يا أيها الذين آمنوا اتقوا الله وآمنوا برسوله يؤتكم كفلين من رحمته ويجعل لكم نورا تمشون به ويغفر لكم ۚ والله غفور رحيم"
    },
    {
        "start": 3422.1,
        "end": 3447.16,
        "text": "لئلا يعلم أهل الكتاب ألا يقدرون على شيء من فضل الله ۙ وأن الفضل بيد الله يؤتيه من يشاء ۚ والله ذو الفضل العظيم"
    }
]